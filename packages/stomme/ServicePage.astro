---
import Cover from './src/Cover.astro';
// The renderer comes through the @stomme/renderer alias (the site's wrapper when
// src/blocks/BlockRenderer.astro exists, else the engine renderer) so a service's
// blocks get the site's custom blocks. Same resolution the lookbook route uses.
import BlockRenderer from '@stomme/renderer';
import { render } from 'astro:content';
import { resolveLink, resolveButton } from './src/href';
import { resolveSite, type SiteConfig } from './src/config';

// Service detail page rendered from a `services` collection entry (its markdown
// body becomes the article). Use in a site's /<services>/[slug].astro route: do
// getStaticPaths there, then
//   <Base title=... description=...><ServicePage service={entry} config={site} /></Base>
// Chrome strings come from site.strings.service; CTA links to site.routes.contact.
// Expects a `services` schema with: title, navLabel, summary?, bullets?, media { image?, imageAlt? },
// seo? + a markdown body + optional `blocks` (composed sections, same
// picker as pages — rendered between the intro and the quote CTA).
//
// A block-composed entry may additionally carry a `hero` frontmatter group. That
// renders a COMPACT page-header instead of the plain one: eyebrow (service string),
// H1 = title, lede = summary, ✓ ticks, primary CTA (contact) plus an optional quiet
// second link (e.g. a "#process" jump), with the service image beside the text.
// Deliberately lighter than the hero block — the big landing-page hero belongs to
// the homepage; a detail page opens like a section, not another landing page.
// No `hero` → the plain header, exactly as before (fleet-safe).
interface Props {
  service?: any; // CollectionEntry<'services'> (the live route)
  data?: any; // OR draft frontmatter (the CMS preview) …
  bodyHtml?: string; // … with the markdown body pre-rendered to HTML
  config?: SiteConfig;
}
const { service, data: draftData, bodyHtml, config } = Astro.props;
const data = service ? service.data : (draftData ?? {});
const site = resolveSite(config);
const t = site.strings.service;
const contact = site.routes.contact ?? '/contact';
const Content = service ? (await render(service)).Content : null;
// Composed entries own the whole page below the header (everything is a section);
// the template's body/bullets/image + the quote-CTA band are the LEGACY layout, kept
// for entries without blocks so existing sites render unchanged.
const hasBlocks = Array.isArray(data.blocks) && data.blocks.length > 0;
// The hero group only upgrades block-composed entries — the legacy layout already
// renders bullets/image itself and must not double them.
const hero = hasBlocks && data.hero && typeof data.hero === 'object' ? data.hero : null;
const hdTicks: string[] = hero
  ? (Array.isArray(hero.ticks) && hero.ticks.length > 0 ? hero.ticks : (data.bullets ?? []))
  : [];
const hdImage = hero ? (hero.image ?? data.media?.image) : undefined;
// Primary CTA always renders (label/link default to the service strings + contact route);
// `cta`/`cta2` are the grouped shape, the flat pairs are legacy content.
const hdCta = hero ? resolveLink(hero.cta?.link ?? hero.ctaHref, contact) : contact;
const hdCtaLabel = hero ? (hero.cta?.label || hero.ctaLabel || t.cta) : t.cta;
const hdBtn2 = hero ? resolveButton(hero.cta2, hero.cta2Label, hero.cta2Href) : null;
---
{hero && (
<section class="section service-hd">
  <div class:list={['service-hd__grid', { 'has-media': !!hdImage }]}>
    <div>
      <span class="mono eyebrow">{t.eyebrow}</span>
      <h1 class="display service-hd__h1">{data.title}</h1>
      {data.summary && <p class="intro service-hd__lede">{data.summary}</p>}
      {hdTicks.length > 0 && (
        <ul class="service-hd__ticks">
          {hdTicks.map((tick: string) => (
            <li><span class="service-hd__check" aria-hidden="true">✓</span><span>{tick}</span></li>
          ))}
        </ul>
      )}
      <div class="service-hd__cta">
        <a href={hdCta} class="btn">{hdCtaLabel}</a>
        {hdBtn2 && (
          <a href={hdBtn2.href} class="btn-ghost">{`${hdBtn2.label} ${hdBtn2.href.startsWith('#') ? '↓' : '→'}`}</a>
        )}
      </div>
    </div>
    {hdImage && (
      <Cover src={hdImage} alt={hero.imageAlt ?? data.media?.imageAlt ?? ''} placeholder="/images/placeholders/service.svg" width={800} height={600} loading="eager" class="service-hd__img" />
    )}
  </div>
</section>
)}
{!hero && (
<section class="section service-page">
  <span class="mono eyebrow">{t.eyebrow}</span>
  <h1 class="display display--hero service-h1">{data.title}</h1>
  {data.summary && <p class="intro service-lede">{data.summary}</p>}
  {!hasBlocks && data.media?.image && (
    <Cover src={data.media?.image} alt={data.media?.imageAlt ?? data.title} placeholder="/images/placeholders/service.svg" width={1200} height={675} loading="eager" class="service-img" />
  )}
  {!hasBlocks && (
    <div class="service-prose">
      {Content ? <Content /> : <Fragment set:html={bodyHtml ?? ''} />}
    </div>
  )}
  {!hasBlocks && data.bullets?.length > 0 && (
    <ul class="service-bullets">{data.bullets.map((b: string) => <li><span class="service-tick">✓</span><span>{b}</span></li>)}</ul>
  )}
</section>
)}

{hasBlocks && <BlockRenderer blocks={data.blocks} config={config} />}

{!hasBlocks && (
  <section class="band">
    <div class="service-cta">
      <div>
        <span class="mono">{t.quoteEyebrow}</span>
        <p class="display service-cta__h">{t.quoteHeading}</p>
      </div>
      <a href={contact} class="btn">{t.cta}</a>
    </div>
  </section>
)}

<style>
  /* Compact page-header (block-composed entries with a `hero` group). Reads as a
     section intro: section-level heading size (not the hero scale), tighter bottom
     padding, image in the side column. */
  .service-hd { padding-bottom: 1.5rem; }
  @media (min-width: 768px) { .service-hd { padding-block: 3rem 2.25rem; } }
  .service-hd__grid { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: center; }
  @media (min-width: 920px) { .service-hd__grid.has-media { grid-template-columns: 1.1fr 0.9fr; gap: clamp(2rem, 4vw, 3.5rem); } }
  /* :global — the image comes out of the Cover child component, so it doesn't
     carry this component's scope attribute. */
  .service-hd__grid > :global(*) { min-width: 0; }
  .service-hd__h1 { margin-top: 1rem; }
  .service-hd__lede { max-width: 36rem; }
  .service-hd__ticks { list-style: none; margin: 1.25rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem; }
  .service-hd__ticks li { display: flex; gap: 0.7rem; align-items: baseline; color: var(--color-ink); font-size: 0.98rem; }
  .service-hd__check { color: var(--color-brand); font-weight: 800; flex: none; }
  .service-hd__cta { margin-top: 1.75rem; display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap; }
  .service-hd__grid :global(.service-hd__img) { width: 100%; height: auto; aspect-ratio: 4 / 3; border-radius: 1rem; border: 1px solid var(--color-line); object-fit: cover; display: block; }

  .service-page { max-width: 48rem; }
  .service-h1 { margin-top: 1rem; }
  .service-img { margin-top: 2rem; aspect-ratio: 16 / 9; width: 100%; border: 1px solid var(--color-line); border-radius: 1rem; object-fit: cover; display: block; }
  .service-prose { margin-top: 2.5rem; color: var(--color-ink); line-height: 1.7; }
  .service-prose :global(p) { margin: 0 0 1rem; }
  .service-prose :global(h2) { font-family: var(--bk-font-display); font-weight: 800; color: var(--color-ink); margin: 2rem 0 0.75rem; }
  .service-prose :global(ul) { margin: 0 0 1rem; padding-left: 1.25rem; }
  .service-bullets { margin: 2rem 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
  .service-bullets li { display: flex; gap: 0.75rem; color: var(--color-ink); }
  .service-tick { color: var(--color-brand); font-weight: 700; }
  .service-cta { max-width: 72rem; margin-inline: auto; padding: 3.5rem 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; align-items: flex-start; }
  @media (min-width: 640px) { .service-cta { flex-direction: row; align-items: center; justify-content: space-between; } }
  .service-cta__h { margin: 0.5rem 0 0; font-size: clamp(1.4rem, 2.5vw, 1.875rem); }
</style>
