---
import Cover from './src/Cover.astro';
import { render } from 'astro:content';
import { resolveSite, type SiteConfig } from './src/config';

// Service detail page rendered from a `services` collection entry (its markdown
// body becomes the article). Use in a site's /<services>/[slug].astro route: do
// getStaticPaths there, then
//   <Base title=... description=...><ServicePage service={entry} config={site} /></Base>
// Chrome strings come from site.strings.service; CTA links to site.routes.contact.
// Expects a `services` schema with: title, navLabel, summary?, bullets?, image?,
// imageAlt?, seo? + a markdown body.
interface Props {
  service: any; // CollectionEntry<'services'>
  config?: SiteConfig;
}
const { service, config } = Astro.props;
const { data } = service;
const site = resolveSite(config);
const t = site.strings.service;
const contact = site.routes.contact ?? '/contact';
const { Content } = await render(service);
---
<section class="section service-page">
  <span class="mono eyebrow">{t.eyebrow}</span>
  <h1 class="display display--hero service-h1">{data.title}</h1>
  {data.image && (
    <Cover src={data.image} alt={data.imageAlt ?? data.title} placeholder="/images/placeholders/service.svg" width={1200} height={675} loading="eager" class="service-img" />
  )}
  <div class="service-prose">
    <Content />
  </div>
  {data.bullets?.length > 0 && (
    <ul class="service-bullets">{data.bullets.map((b: string) => <li><span class="service-tick">✓</span><span>{b}</span></li>)}</ul>
  )}
</section>

<section class="band">
  <div class="service-cta">
    <div>
      <span class="mono">{t.quoteEyebrow}</span>
      <p class="display service-cta__h">{t.quoteHeading}</p>
    </div>
    <a href={contact} class="btn">{t.cta}</a>
  </div>
</section>

<style>
  .service-page { max-width: 48rem; }
  .service-h1 { margin-top: 1rem; }
  .service-img { margin-top: 2rem; aspect-ratio: 16 / 9; width: 100%; border: 1px solid var(--color-line); border-radius: 1rem; object-fit: cover; display: block; }
  .service-prose { margin-top: 2.5rem; color: var(--color-ink); line-height: 1.7; }
  .service-prose :global(p) { margin: 0 0 1rem; }
  .service-prose :global(h2) { font-family: var(--bk-font-display); font-weight: 800; color: var(--color-ink); margin: 2rem 0 0.75rem; }
  .service-prose :global(ul) { margin: 0 0 1rem; padding-left: 1.25rem; }
  .service-bullets { margin: 2rem 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
  .service-bullets li { display: flex; gap: 0.75rem; color: var(--color-ink); }
  .service-tick { color: var(--color-brand); font-weight: 700; }
  .service-cta { max-width: 72rem; margin-inline: auto; padding: 3.5rem 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; align-items: flex-start; }
  @media (min-width: 640px) { .service-cta { flex-direction: row; align-items: center; justify-content: space-between; } }
  .service-cta__h { margin: 0.5rem 0 0; font-size: clamp(1.4rem, 2.5vw, 1.875rem); }
</style>
