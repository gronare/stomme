---
// Injected by the stomme integration when `features.blog` is on. Renders inside
// the SITE's Base (aliased) so chrome/theme match; the post template + the site's
// site config come from the package + the site's config alias.
import Base from '@stomme/base';
import { site } from '@stomme/config';
import PostPage from '../PostPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}
const { post } = Astro.props;
---
<Base title={post.data.title} description={post.data.excerpt} image={post.data.cover}>
  <PostPage post={post} config={site} />
</Base>
