---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Renders a content image through Astro's optimizer when it's a real uploaded
// raster image (stored under /src/assets/uploads via the CMS), and falls back to
// a plain <img> for SVG placeholders or public-path images that can't be optimized.
// width/height are optional — omit them to use the image's intrinsic size (good
// for `object-contain` framing); pass them for fixed `object-cover` slots.
interface Props {
  src?: string; // value stored in frontmatter (may be undefined)
  alt: string;
  width?: number;
  height?: number;
  placeholder: string; // public path to the placeholder SVG
  class?: string;
  loading?: 'eager' | 'lazy';
}
const { src, alt, width, height, placeholder, class: cls, loading = 'lazy' } = Astro.props;

const uploads = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/uploads/**/*.{jpg,jpeg,png,webp,avif}',
);
const optimized = src && uploads[src] ? uploads[src] : null;
const dims = { ...(width ? { width } : {}), ...(height ? { height } : {}) };
---

{
  optimized ? (
    <Image src={optimized()} alt={alt} {...dims} class={cls} loading={loading} />
  ) : (
    <img src={src ?? placeholder} alt={alt} {...dims} loading={loading} class={cls} decoding="async" />
  )
}
