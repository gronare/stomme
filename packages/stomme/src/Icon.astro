---
// Renders a named glyph from the engine icon library (src/icons.ts) — referenced
// by name from block data (hero flow, feature cards, contact card). Static inline
// SVG only: zero JS, no external requests. An unknown/legacy name degrades to the
// fallback glyph instead of breaking the page.
import { ICONS, FALLBACK_ICON } from './icons.ts';
interface Props { name?: string; class?: string }
const { name = FALLBACK_ICON, class: cls } = Astro.props;
const path = ICONS[name] ?? ICONS[FALLBACK_ICON];
---
<svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={path} />
