---
// Generic block renderer with the library blocks built in. Pass `blocks`; the
// default registry maps the standard types to the library components. Add or
// override with the optional `registry` prop (your custom blocks win on key clash).
import Hero from '../blocks/Hero.astro';
import CoverHero from '../blocks/CoverHero.astro';
import PageHeader from '../blocks/PageHeader.astro';
import Prose from '../blocks/Prose.astro';
import FeatureGrid from '../blocks/FeatureGrid.astro';
import ServiceGrid from '../blocks/ServiceGrid.astro';
import Pillars from '../blocks/Pillars.astro';
import Plans from '../blocks/Plans.astro';
import SpecialistGrid from '../blocks/SpecialistGrid.astro';
import Steps from '../blocks/Steps.astro';
import Checklist from '../blocks/Checklist.astro';
import Gallery from '../blocks/Gallery.astro';
import BeforeAfter from '../blocks/BeforeAfter.astro';
import TextImage from '../blocks/TextImage.astro';
import TextQuote from '../blocks/TextQuote.astro';
import Callout from '../blocks/Callout.astro';
import Definition from '../blocks/Definition.astro';
import Fragment_ from '../blocks/Fragment.astro';
import StatPanel from '../blocks/StatPanel.astro';
import Testimonials from '../blocks/Testimonials.astro';
import LinkChips from '../blocks/LinkChips.astro';
import PostList from '../blocks/PostList.astro';
import CatalogList from '../blocks/CatalogList.astro';
import CtaPanel from '../blocks/CtaPanel.astro';
import CtaBox from '../blocks/CtaBox.astro';
import Faq from '../blocks/Faq.astro';
import StatsBar from '../blocks/StatsBar.astro';
import LogoStrip from '../blocks/LogoStrip.astro';
import ContactForm from '../blocks/ContactForm.astro';
import ContactCard from '../blocks/ContactCard.astro';
import FindUs from '../blocks/FindUs.astro';
import { resolveSite, resolveFeatures, type SiteConfig, type StommeFeatures } from './config';

const defaults: Record<string, any> = {
  hero: Hero,
  cover: CoverHero,
  pageHeader: PageHeader,
  prose: Prose,
  featureGrid: FeatureGrid,
  serviceGrid: ServiceGrid,
  pillars: Pillars,
  plans: Plans,
  specialistGrid: SpecialistGrid,
  steps: Steps,
  checklist: Checklist,
  gallery: Gallery,
  beforeAfter: BeforeAfter,
  textImage: TextImage,
  textQuote: TextQuote,
  callout: Callout,
  definition: Definition,
  fragment: Fragment_,
  statPanel: StatPanel,
  testimonials: Testimonials,
  linkChips: LinkChips,
  postList: PostList,
  catalogList: CatalogList,
  ctaPanel: CtaPanel,
  ctaBox: CtaBox,
  faq: Faq,
  statsBar: StatsBar,
  logoStrip: LogoStrip,
  contactForm: ContactForm,
  contactCard: ContactCard,
  findUs: FindUs,
};

interface Props {
  blocks?: { type: string; style?: { surface?: string }; [key: string]: unknown }[];
  registry?: Record<string, any>;
  config?: SiteConfig;
  features?: StommeFeatures;
}
const { blocks = [], registry = {}, config, features } = Astro.props;
const reg = { ...defaults, ...registry };
// Resolved per-site config (routes/locale/strings), forwarded to every block as
// `site` so blocks needn't be wired individually.
const site = resolveSite(config);
// Feature gating. contactForm is the only block gated here and it defaults ON, so a page
// that passes no `features` (or doesn't set the flag) renders exactly as before (rule
// zero). Only an explicit contactForm:false drops the block. Gating SKIPS existing blocks
// — it never injects one — so a page with no contactForm block is unaffected.
const feats = resolveFeatures(features);
const rendered = feats.contactForm === false ? blocks.filter((b) => b.type !== 'contactForm') : blocks;

const surfaceClass: Record<string, string> = { tint: 'surface-tint', band: 'band', dark: 'surface-dark', gradient: 'surface-gradient' };
---
{
  rendered.map((block) => {
    const Component = reg[block.type];
    if (!Component) {
      return (
        <div class="section" style="color:#b00020">
          ⚠ Unknown block: <code>{block.type}</code>
        </div>
      );
    }
    // Grouped shape (block-field convention): the surface lives at style.surface.
    const surf = block.style?.surface ? surfaceClass[block.style.surface] : undefined;
    return surf ? (
      <div class={surf}>
        <Component {...block} site={site} />
      </div>
    ) : (
      <Component {...block} site={site} />
    );
  })
}
