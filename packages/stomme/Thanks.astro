---
// Contact-form confirmation — the real /thanks page AND the CMS "Thank-you" preview render
// this (via /preview?kind=thanks), so the preview shows the live page with the site theme.
// Presentational: the caller resolves the copy (settings → localized fallback) and passes it.
interface Props {
  eyebrow?: string;
  heading: string;
  message: string;
  button: string;
  showContact?: boolean;
  directLabel?: string;
  phone?: string;
  phoneE164?: string;
  email?: string;
  hours?: string;
}
const { eyebrow = 'Message sent', heading, message, button, showContact, directLabel = 'Direct contact', phone, phoneE164, email, hours } = Astro.props;
---
<section class="section">
  <div class="contact-sent contact-sent--center">
    <div class="cs-badge"><svg viewBox="0 0 56 56" aria-hidden="true"><circle cx="28" cy="28" r="26"></circle><path d="M17 29.5 L24.5 37 L40 20"></path></svg></div>
    <p class="cs-eyebrow">{eyebrow}</p>
    <h1 class="cs-head">{heading}</h1>
    <p class="cs-lead">{message}</p>
    <div class="cs-actions"><a class="btn" href="/">{button}</a></div>
    {showContact && (phone || email) && (
      <aside class="cs-direct">
        <p class="cs-label">{directLabel}</p>
        {phone && <p class="cs-phone"><a href={`tel:${phoneE164 || phone}`}>{phone}</a></p>}
        {email && <p class="cs-email"><a href={`mailto:${email}`}>{email}</a></p>}
        {hours && <p class="cs-hours">{hours}</p>}
      </aside>
    )}
  </div>
</section>
