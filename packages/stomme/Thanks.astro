---
// Contact-form confirmation — the real /thanks page AND the CMS "Thank-you" preview render
// this (via /preview?kind=thanks), so the preview shows the live page with the site theme.
// Presentational: the caller resolves copy/links/recap and passes them in. Matches the
// confirmation mockup — centered success, then a two-up of the "what you sent" recap and the
// shared direct-contact card (DirectContact.astro, same as the contact page).
import DirectContact from './DirectContact.astro';
interface Recap {
  emailLabel?: string; email?: string;
  phoneLabel?: string; phone?: string;
  messageLabel?: string; message?: string;
}
interface Props {
  eyebrow?: string;
  heading: string;
  message: string;
  primaryLabel: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  recapLabel?: string;
  recap?: Recap | null;
  showContact?: boolean;
  talkLabel?: string;
  who?: string;
}
const {
  eyebrow = 'Message sent', heading, message,
  primaryLabel, primaryHref = '/', secondaryLabel, secondaryHref = '/',
  recapLabel = 'What you sent', recap = null,
  showContact, talkLabel = 'Prefer to talk?', who,
} = Astro.props;

const hasRecap = !!recap && !!(recap.email || recap.phone || recap.message);
const hasDirect = showContact === true; // opt-in (rule zero); the route gates this on contact actually existing
const twoCol = hasRecap && hasDirect;
---
<section class="section thanks-confirm" data-recap-label={recapLabel}>
  <div class="confirm-badge"><svg viewBox="0 0 56 56" aria-hidden="true"><circle cx="28" cy="28" r="26"></circle><path d="M17 29.5 L24.5 37 L40 20"></path></svg></div>
  <span class="mono eyebrow confirm-eyebrow">{eyebrow}</span>
  {heading && <h1 class="confirm-head">{heading}</h1>}
  {message && <p class="confirm-lead">{message}</p>}
  {(primaryLabel || secondaryLabel) && (
    <div class="confirm-actions">
      {primaryLabel && <a class="btn" href={primaryHref}>{primaryLabel}</a>}
      {secondaryLabel && <a class="btn btn-outline" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</section>

{(hasRecap || hasDirect) && (
  <div class:list={['thanks-cols', !twoCol && 'thanks-cols--solo']}>
    {hasRecap && (
      <section class="confirm-card" aria-label={recapLabel}>
        <p class="mono eyebrow confirm-label">{recapLabel}</p>
        <dl class="confirm-recap-dl">
          {recap!.email && (<><dt>{recap!.emailLabel ?? 'Email'}</dt><dd>{recap!.email}</dd></>)}
          {recap!.phone && (<><dt>{recap!.phoneLabel ?? 'Phone'}</dt><dd>{recap!.phone}</dd></>)}
          {recap!.message && (
            <div class="confirm-msg">
              <dt>{recap!.messageLabel ?? 'Message'}</dt>
              <dd>{recap!.message}</dd>
            </div>
          )}
        </dl>
      </section>
    )}
    {hasDirect && (
      <DirectContact label={talkLabel} show={{ phone: true, email: true }} footer={who} tint />
    )}
  </div>
)}

<script is:inline>
  // A real form submit lands here from /thanks with a recap of what was sent stashed in
  // sessionStorage (the page is static — it ships no submitted data). Build the "what you
  // sent" card from it, drop it into the two-up, then clear it so a refresh won't re-show.
  // No stash (direct visit / no-JS) → nothing happens, the generic thank-you stands alone.
  (function () {
    var raw; try { raw = sessionStorage.getItem('stomme:recap'); } catch (e) { return; }
    if (!raw) return;
    var d; try { d = JSON.parse(raw); } catch (e) { return; }
    try { sessionStorage.removeItem('stomme:recap'); } catch (e) {}
    if (!d || !(d.email || d.phone || d.message)) return;

    var confirmEl = document.querySelector('.thanks-confirm');
    if (!confirmEl) return;
    var cols = confirmEl.nextElementSibling;
    if (!cols || !cols.classList || !cols.classList.contains('thanks-cols')) {
      cols = document.createElement('div');
      cols.className = 'thanks-cols thanks-cols--solo';
      confirmEl.insertAdjacentElement('afterend', cols);
    }
    if (cols.querySelector('.confirm-card')) return; // already rendered server-side

    var L = d.labels || {};
    var esc = function (s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); };
    var rows = '';
    if (d.email) rows += '<dt>' + esc(L.email || 'Email') + '</dt><dd>' + esc(d.email) + '</dd>';
    if (d.phone) rows += '<dt>' + esc(L.phone || 'Phone') + '</dt><dd>' + esc(d.phone) + '</dd>';
    if (d.message) rows += '<div class="confirm-msg"><dt>' + esc(L.message || 'Message') + '</dt><dd>' + esc(d.message) + '</dd></div>';

    var card = document.createElement('section');
    card.className = 'confirm-card';
    card.innerHTML = '<p class="mono eyebrow confirm-label">' + esc(confirmEl.getAttribute('data-recap-label') || 'What you sent') +
      '</p><dl class="confirm-recap-dl">' + rows + '</dl>';
    cols.insertAdjacentElement('afterbegin', card);
    if (cols.children.length > 1) cols.classList.remove('thanks-cols--solo');
  })();
</script>
