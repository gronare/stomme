---
// Contact-form confirmation — the real /thanks page AND the CMS "Thank-you" preview render
// this (via /preview?kind=thanks), so the preview shows the live page with the site theme.
// Presentational: the caller resolves copy/links/recap and passes them in. Matches the
// confirmation mockup — centered success, then a two-up of the "what you sent" recap and the
// shared direct-contact card (DirectContact.astro, same as the contact page).
import DirectContact from './DirectContact.astro';
interface Recap {
  emailLabel?: string; email?: string;
  phoneLabel?: string; phone?: string;
  messageLabel?: string; message?: string;
}
interface Props {
  eyebrow?: string;
  heading: string;
  message: string;
  primaryLabel: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  recapLabel?: string;
  recap?: Recap | null;
  showContact?: boolean;
  talkLabel?: string;
  who?: string;
}
const {
  eyebrow = 'Message sent', heading, message,
  primaryLabel, primaryHref = '/', secondaryLabel, secondaryHref = '/',
  recapLabel = 'What you sent', recap = null,
  showContact, talkLabel = 'Prefer to talk?', who,
} = Astro.props;

const hasRecap = !!recap && !!(recap.email || recap.phone || recap.message);
const hasDirect = showContact !== false; // the route gates this on contact actually existing
const twoCol = hasRecap && hasDirect;
---
<section class="section thanks-confirm">
  <div class="confirm-badge"><svg viewBox="0 0 56 56" aria-hidden="true"><circle cx="28" cy="28" r="26"></circle><path d="M17 29.5 L24.5 37 L40 20"></path></svg></div>
  <span class="mono eyebrow confirm-eyebrow">{eyebrow}</span>
  {heading && <h1 class="confirm-head">{heading}</h1>}
  {message && <p class="confirm-lead">{message}</p>}
  {(primaryLabel || secondaryLabel) && (
    <div class="confirm-actions">
      {primaryLabel && <a class="btn" href={primaryHref}>{primaryLabel}</a>}
      {secondaryLabel && <a class="btn btn-outline" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</section>

{(hasRecap || hasDirect) && (
  <div class:list={['thanks-cols', !twoCol && 'thanks-cols--solo']}>
    {hasRecap && (
      <section class="confirm-card" aria-label={recapLabel}>
        <p class="mono eyebrow confirm-label">{recapLabel}</p>
        <dl class="confirm-recap-dl">
          {recap!.email && (<><dt>{recap!.emailLabel ?? 'Email'}</dt><dd>{recap!.email}</dd></>)}
          {recap!.phone && (<><dt>{recap!.phoneLabel ?? 'Phone'}</dt><dd>{recap!.phone}</dd></>)}
          {recap!.message && (
            <div class="confirm-msg">
              <dt>{recap!.messageLabel ?? 'Message'}</dt>
              <dd>{recap!.message}</dd>
            </div>
          )}
        </dl>
      </section>
    )}
    {hasDirect && (
      <DirectContact label={talkLabel} show={{ phone: true, email: true }} footer={who} tint />
    )}
  </div>
)}
