{
  "name": "@gronare/stomme",
  "version": "0.1.79",
  "description": "Block-CMS engine for Astro + Decap — types, helpers, runtime components, tooling.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gronare/stomme.git"
  },
  "exports": {
    "./kit": "./src/kit.ts",
    "./href": "./src/href.ts",
    "./markdown": "./src/markdown.ts",
    "./fonts": "./src/fonts.ts",
    "./config": "./src/config.ts",
    "./contact": "./src/contact.ts",
    "./catalog": "./catalog.ts",
    "./collections": "./collections.ts",
    "./addon-collections": "./addon-collections.ts",
    "./integration": {
      "types": "./integration.d.ts",
      "default": "./integration.mjs"
    },
    "./styles.css": "./styles.css",
    "./Cover.astro": "./src/Cover.astro",
    "./Icon.astro": "./src/Icon.astro",
    "./BlockRenderer.astro": "./src/BlockRenderer.astro",
    "./Header.astro": "./blocks/Header.astro",
    "./Footer.astro": "./blocks/Footer.astro",
    "./Head.astro": "./Head.astro",
    "./Thanks.astro": "./Thanks.astro",
    "./Tracking.astro": "./Tracking.astro",
    "./ConsentBanner.astro": "./ConsentBanner.astro",
    "./DirectContact.astro": "./DirectContact.astro",
    "./ContactLink.astro": "./ContactLink.astro",
    "./TownPage.astro": "./TownPage.astro",
    "./ServicePage.astro": "./ServicePage.astro",
    "./PostPage.astro": "./PostPage.astro",
    "./CatalogPage.astro": "./CatalogPage.astro",
    "./routes/*": "./routes/*",
    "./blocks/*": "./blocks/*"
  },
  "scripts": {
    "gen:schema-manifest": "node bin/gen-schema-manifest.mjs",
    "gen:blocks-manifest": "node bin/gen-blocks-manifest.mjs",
    "test:preview-workerd": "node test/smoke-preview-workerd.mjs",
    "test:og": "node test/smoke-og.mjs",
    "test:admin-contract": "node test/admin-contract.mjs"
  },
  "bin": {
    "stomme-gen": "bin/gen-admin-blocks.mjs",
    "stomme-gen-schema": "bin/gen-schema-manifest.mjs",
    "stomme-gen-blocks": "bin/gen-blocks-manifest.mjs",
    "stomme-new-block": "bin/new-block.mjs",
    "stomme-lint-styles": "bin/lint-styles.mjs"
  },
  "files": [
    "src",
    "bin",
    "admin",
    "assets",
    "blocks",
    "routes",
    "catalog.ts",
    "collections.ts",
    "addon-collections.ts",
    "schema-manifest.json",
    "blocks-manifest.json",
    "integration.mjs",
    "integration.d.ts",
    "DirectContact.astro",
    "ContactLink.astro",
    "Head.astro",
    "Thanks.astro",
    "TownPage.astro",
    "ServicePage.astro",
    "PostPage.astro",
    "CatalogPage.astro",
    "styles.css"
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/inter-tight": "^5.2.7",
    "@resvg/resvg-js": "^2.6.2",
    "jiti": "^2.6.0",
    "marked": "^18.0.5",
    "satori": "^0.26.0",
    "sharp": "^0.35.3"
  },
  "peerDependencies": {
    "astro": ">=5"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1"
  },
  "license": "AGPL-3.0-only"
}
