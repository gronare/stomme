---
import { getEntry } from 'astro:content';
import DirectContact from '../DirectContact.astro';

// Contact form block — self-contained: heading, intro, field labels, submit text and the
// direct-contact toggle are all editable on the block. On submit it stashes a recap of
// what was sent in sessionStorage and goes to /thanks, which renders the confirmation +
// recap (one place — no inline duplicate). No-JS posts to the endpoint, which 303s to /thanks.
interface Props {
  site?: any; eyebrow?: string; heading?: string; intro?: string;
  labelName?: string; labelEmail?: string; labelMessage?: string;
  submitLabel?: string; showPhone?: boolean; showDirectContact?: boolean;
}
const { site, eyebrow, heading, intro, labelName, labelEmail, labelMessage, submitLabel, showPhone, showDirectContact } = Astro.props;
const c = site?.strings?.contact ?? {};
// Labels are editable but never empty: a blank field falls back to the localized default.
const L = {
  name: labelName || (c.name ?? 'Name'),
  email: labelEmail || (c.email ?? 'Email'),
  phone: c.phone ?? 'Phone',
  message: labelMessage || (c.message ?? 'Describe your project'),
  submit: submitLabel || (c.submit ?? 'Send request'),
  direct: c.direct ?? 'Direct contact',
  honeypot: c.honeypot ?? 'Leave this field empty',
};
const showPhoneField = showPhone === true; // opt-in (rule zero): absent = hidden
const showAside = showDirectContact === true; // opt-in: absent or off → full-width form

const settings = (await getEntry('settings', 'site'))!.data;
const contact = ((await getEntry('contact', 'contact').catch(() => null))?.data ?? {}) as any;
const contactLine = [settings.name, contact.address?.city, contact.orgNr && `Org.nr ${contact.orgNr}`]
  .filter(Boolean)
  .join(' · ');

// Post to the form gateway (spam-gate + rate limit at the edge; the control plane stores + sends).
// `contact.endpoint` is the dedicated form worker; falls back to the legacy cms.baseUrl for
// sites not yet migrated, then to the per-site /api/contact if un-wired.
const contactAction = site?.contact?.endpoint
  ? `${site.contact.endpoint}/contact`
  : site?.cms?.baseUrl ? `${site.cms.baseUrl}/contact` : '/api/contact';
// No-JS fallback: the worker 303s here after a successful submit (KV is gone, so the
// success path travels with the form). JS submits ignore this and go to /thanks themselves.
const successPath = site?.routes?.formSuccess ?? '/thanks';

// The "what you sent" recap on /thanks is labelled with this form's own field labels.
const recapLabels = JSON.stringify({ email: L.email, phone: L.phone, message: L.message });
---
<section class="section">
  {(heading || intro) && (
    <div class="contact-head">
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      {heading && <h1 class="contact-h1" style={eyebrow ? 'margin-top:0.75rem' : ''}>{heading}</h1>}
      {intro && <p class="contact-intro">{intro}</p>}
    </div>
  )}
  <div class:list={['contact-grid', !showAside && 'contact-grid--solo']}>
    <form method="POST" action={contactAction} class="contact-form" data-recap-labels={recapLabels} data-success={successPath}>
      {/* Honeypot — hidden INLINE so no stylesheet-subset context (CMS preview) can show it. */}
      <p class="hp" aria-hidden="true" style="display:none"><label>{L.honeypot} <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
      {/* No-JS success path — the form worker 303s to this on the site's own origin. */}
      <input type="hidden" name="_success" value={successPath} />
      <div class="field">
        <label for="name" class="mono">{L.name}</label>
        <input id="name" name="name" required />
      </div>
      <div class="field">
        <label for="email" class="mono">{L.email}</label>
        <input id="email" name="email" type="email" required />
      </div>
      {showPhoneField && (
        <div class="field">
          <label for="phone" class="mono">{L.phone}</label>
          <input id="phone" name="phone" type="tel" />
        </div>
      )}
      <div class="field">
        <label for="message" class="mono">{L.message}</label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>
      <button type="submit" class="btn">{L.submit}</button>
    </form>

    {showAside && (
      <DirectContact label={L.direct} show={{ phone: true, email: true, hours: true }} footer={contactLine} />
    )}
  </div>
  <script is:inline>
    // Progressive enhancement: submit via fetch, stash a recap of what was sent in
    // sessionStorage, then go to /thanks (it renders the confirmation + recap — one place,
    // no inline duplicate). No-JS just POSTs and the endpoint 303s to /thanks.
    (function () {
      var form = document.currentScript.closest('section').querySelector('.contact-form');
      if (!form) return;
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type=submit]');
        if (btn) btn.disabled = true;
        var fd = new FormData(form);
        try {
          var res = await fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json', 'X-Requested-With': 'fetch' } });
          if (!res.ok) throw new Error('send failed');
          try {
            var labels = null; try { labels = JSON.parse(form.dataset.recapLabels || 'null'); } catch (e) {}
            sessionStorage.setItem('stomme:recap', JSON.stringify({
              email: fd.get('email') || '', phone: fd.get('phone') || '', message: fd.get('message') || '', labels: labels,
            }));
          } catch (e) {}
          window.location.assign(form.dataset.success || '/thanks');
        } catch (err) {
          if (btn) btn.disabled = false;
          var msg = form.querySelector('.contact-error');
          if (!msg) { msg = document.createElement('p'); msg.className = 'contact-error'; form.appendChild(msg); }
          msg.textContent = 'Sorry — could not send. Please try again or email us directly.';
        }
      });
    })();
  </script>
</section>
