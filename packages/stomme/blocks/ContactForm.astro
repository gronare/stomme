---
import { getEntry } from 'astro:content';

// Contact form block — self-contained: heading, intro, field labels, submit text and the
// direct-contact toggle are all editable on the block. The thank-you copy (inline
// confirmation + /thanks) is the single source in the "Thank-you" settings, localized.
interface Props {
  site?: any; heading?: string; intro?: string;
  labelName?: string; labelEmail?: string; labelPhone?: string; labelMessage?: string;
  submitLabel?: string; showDirectContact?: boolean;
}
const { site, heading, intro, labelName, labelEmail, labelPhone, labelMessage, submitLabel, showDirectContact } = Astro.props;
const c = site?.strings?.contact ?? {};
const L = {
  name: labelName || (c.name ?? 'Name'),
  email: labelEmail || (c.email ?? 'Email'),
  phone: labelPhone || (c.phone ?? 'Phone'),
  message: labelMessage || (c.message ?? 'Describe your project'),
  submit: submitLabel || (c.submit ?? 'Send request'),
  direct: c.direct ?? 'Direct contact',
};
const showAside = showDirectContact !== false; // default on; off → full-width form

const settings = (await getEntry('settings', 'site'))!.data;
const contactLine = [settings.name, settings.hq, settings.orgNr && `Org.nr ${settings.orgNr}`]
  .filter(Boolean)
  .join(' · ');

// Send through the gateway (Resend key + rate limit live there, one place for all sites).
// Falls back to the per-site /api/contact endpoint if the site isn't CMS/gateway-wired.
const contactAction = site?.cms?.baseUrl ? `${site.cms.baseUrl}/contact` : '/api/contact';

// Thank-you copy: single source = the "Thank-you" settings (optional), localized fallback.
const tset: any = (await getEntry('thanks', 'thanks').catch(() => null))?.data ?? {};
const tk = (site?.strings?.thanks ?? {}) as Record<string, string>;
const thanksData = {
  eyebrow: tk.eyebrow ?? 'Message sent',
  heading: tset.heading || (tk.heading ?? "Thanks{name} — it's on its way."),
  lead: tset.message || (tk.lead ?? "We've got your message and we'll reply within one business day."),
  recapLabel: tk.recapLabel ?? 'What you sent',
  email: L.email, phone: L.phone, message: L.message,
};
---
<section class="section">
  {(heading || intro) && (
    <div class="contact-head">
      {heading && <h1 class="contact-h1">{heading}</h1>}
      {intro && <p class="contact-intro">{intro}</p>}
    </div>
  )}
  <div class:list={['contact-grid', !showAside && 'contact-grid--solo']}>
    <form method="POST" action={contactAction} class="contact-form" data-thanks={JSON.stringify(thanksData)}>
      <p class="hp" aria-hidden="true"><label>Don’t fill this in: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
      <div class="field">
        <label for="name" class="mono">{L.name}</label>
        <input id="name" name="name" required />
      </div>
      <div class="field">
        <label for="email" class="mono">{L.email}</label>
        <input id="email" name="email" type="email" required />
      </div>
      <div class="field">
        <label for="phone" class="mono">{L.phone}</label>
        <input id="phone" name="phone" type="tel" />
      </div>
      <div class="field">
        <label for="message" class="mono">{L.message}</label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>
      <button type="submit" class="btn">{L.submit}</button>
    </form>

    {showAside && (
      <aside class="contact-aside">
        <span class="mono mono-dot">{L.direct}</span>
        {settings.phone && <p class="phone"><a href={`tel:${settings.phoneE164}`}>{settings.phone}</a></p>}
        {settings.email && <p class="email"><a href={`mailto:${settings.email}`}>{settings.email}</a></p>}
        {settings.openingHours && <p class="hours">{settings.openingHours}</p>}
        {contactLine && <p class="mono org">{contactLine}</p>}
      </aside>
    )}
  </div>
  <script is:inline>
    // Progressive enhancement: submit via fetch and replace the form with a
    // confirmation that shows what was sent. No-JS falls back to a plain POST → /thanks.
    (function () {
      var form = document.currentScript.closest('section').querySelector('.contact-form');
      if (!form) return;
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type=submit]');
        if (btn) btn.disabled = true;
        var fd = new FormData(form);
        try {
          var res = await fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json', 'X-Requested-With': 'fetch' } });
          if (!res.ok) throw new Error('send failed');
          var t = {}; try { t = JSON.parse(form.dataset.thanks || '{}'); } catch (e) {}
          var name = (fd.get('name') || '').trim();
          var sent = document.createElement('div');
          sent.className = 'contact-sent';
          var badge = document.createElement('div');
          badge.className = 'cs-badge';
          badge.innerHTML = '<svg viewBox="0 0 56 56" aria-hidden="true"><circle cx="28" cy="28" r="26"/><path d="M17 29.5 L24.5 37 L40 20"/></svg>';
          sent.appendChild(badge);
          var eb = document.createElement('p'); eb.className = 'cs-eyebrow'; eb.textContent = t.eyebrow || 'Message sent'; sent.appendChild(eb);
          var h = document.createElement('h2'); h.className = 'cs-head';
          h.textContent = (t.heading || "Thanks{name} — it's on its way.").replace('{name}', name ? ', ' + name : '');
          sent.appendChild(h);
          var lead = document.createElement('p'); lead.className = 'cs-lead'; lead.textContent = t.lead || ''; sent.appendChild(lead);
          var recap = document.createElement('div'); recap.className = 'cs-recap';
          var rl = document.createElement('p'); rl.className = 'cs-label'; rl.textContent = t.recapLabel || 'What you sent'; recap.appendChild(rl);
          var dl = document.createElement('dl');
          [[t.email || 'Email', fd.get('email')], [t.phone || 'Phone', fd.get('phone')]].forEach(function (row) {
            if (!row[1]) return;
            var dt = document.createElement('dt'); dt.textContent = row[0];
            var dd = document.createElement('dd'); dd.textContent = row[1];
            dl.appendChild(dt); dl.appendChild(dd);
          });
          if (fd.get('message')) {
            var wrap = document.createElement('div'); wrap.className = 'cs-msg';
            var mdt = document.createElement('dt'); mdt.textContent = t.message || 'Message';
            var mdd = document.createElement('dd'); mdd.textContent = fd.get('message');
            wrap.appendChild(mdt); wrap.appendChild(mdd); dl.appendChild(wrap);
          }
          recap.appendChild(dl); sent.appendChild(recap);
          form.replaceWith(sent);
        } catch (err) {
          if (btn) btn.disabled = false;
          var msg = form.querySelector('.contact-error');
          if (!msg) { msg = document.createElement('p'); msg.className = 'contact-error'; form.appendChild(msg); }
          msg.textContent = 'Sorry — could not send. Please try again or email us directly.';
        }
      });
    })();
  </script>
</section>
