---
// Partner / client names with an optional lead-in. Content lives on the block instance.
interface Props { lead?: string; logos?: string[] }
const { lead, logos } = Astro.props;
const names = Array.isArray(logos) ? logos.filter(Boolean) : [];
---
{names.length > 0 && (
  <section class="partner-strip">
    <div class="section" style="text-align:center">
      {lead && <p class="mono">{lead}</p>}
      <div class="partner-logos">{names.map((p) => <span>{p}</span>)}</div>
    </div>
  </section>
)}
