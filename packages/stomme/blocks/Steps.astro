---
// Numbered process / steps. A bordered, hairline-separated list of rows, each
// with a round brand number badge — reads as a sequence (narrow reading measure).
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  items?: { title: string; body: string; kicker?: string }[];
  layout?: { width?: 'narrow' | 'full' };
  anchor?: string;
}
const { eyebrow, heading, intro, items = [], anchor } = Astro.props;
const width = Astro.props.layout?.width ?? 'narrow';
---

{(heading || items.length > 0) && (
  <section id={anchor || undefined} class:list={['section', { 'section--read': width !== 'full' }]}>
    {(eyebrow || heading || intro) && (
      <div class="section-head">
        {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
        {heading && <h2 class="display steps__heading">{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}
    <ol class="steps-track">
      {items.map((s, i) => (
        <li class="step">
          <span class="step__n">{String(i + 1).padStart(2, '0')}</span>
          <div>
            {s.kicker && <span class="mono step__kicker">{s.kicker}</span>}
            <h3 class="step__title">{s.title}</h3>
            <p class="step__body">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}
