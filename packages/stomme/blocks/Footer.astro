---
import { getEntry } from 'astro:content';
import { resolveLink } from '../src/href';

// Themeable site chrome (footer). Reads the navigation/footer/settings collections
// by default; accepts them as optional props (CMS preview drafts). Renders a links
// column + org line only when those fields are present, so a minimal site stays simple.
interface NavData {}
interface FooterData { dark?: boolean; tagline?: string; showLinks?: boolean; linksHeading?: string; links?: { label: string; link?: unknown }[]; showTowns?: boolean; townsHeading?: string; legal?: { label: string; link?: unknown }[]; note?: string; showLogo?: boolean; showWordmark?: boolean }
interface SettingsData { name?: string; logo?: { textPre?: string; textAccent?: string; image?: string; alt?: string } }
interface ContactData { email?: string; phone?: string; phoneE164?: string; hq?: string; orgNr?: string; founded?: string }
// `towns` + `townsHref` are optional: pass them (the site reads its towns collection
// and forwards site.routes.towns) to render a service-area column when footer.showTowns.
// Towns-less sites simply don't pass them, so nothing extra renders.
interface Props { nav?: NavData; footer?: FooterData; settings?: SettingsData; contact?: ContactData; towns?: { id: string; name: string }[]; townsHref?: string }

let { nav, footer, settings, contact, towns, townsHref } = Astro.props;
if (!nav) nav = (await getEntry('navigation', 'nav'))!.data as NavData;
if (!footer) footer = (await getEntry('footer', 'footer'))!.data as FooterData;
if (!settings) settings = (await getEntry('settings', 'site'))!.data as SettingsData;
if (!contact) contact = (((await getEntry('contact', 'contact').catch(() => null))?.data) ?? {}) as ContactData;

const logo = settings.logo ?? {};
const showMark = footer.showLogo !== false && !!logo.image;
const showWord = footer.showWordmark !== false && (!!logo.textPre || !logo.image);
const links = footer.links ?? [];
const legal = footer.legal ?? [];
const tagline = [footer.tagline, contact.hq].filter(Boolean).join(' · ');
const orgLine = [contact.orgNr && `Org.nr ${contact.orgNr}`, contact.founded && `Est. ${contact.founded}`].filter(Boolean).join(' · ');
const year = new Date().getFullYear();
---
<footer class:list={['site-footer', { 'site-footer--dark': footer.dark }]}>
  <div class="inner">
    <div class="footer-grid">
      <div>
        <div class="logo" style="margin:0">
          {showMark && <img class="logo-mark" src={logo.image} alt="" />}
          {showWord && <span class="logo-word">{logo.textPre || settings.name}<span class="accent">{logo.textAccent}</span></span>}
        </div>
        {tagline && <p style="margin:0.5rem 0 0;max-width:36rem">{tagline}</p>}
        {(contact.phone || contact.email) && (
          <p style="margin:0.75rem 0 0">
            {contact.phone && <a href={`tel:${contact.phoneE164}`} class="footer-link">{contact.phone}</a>}
            {contact.phone && contact.email && <span> · </span>}
            {contact.email && <a href={`mailto:${contact.email}`} class="footer-link">{contact.email}</a>}
          </p>
        )}
        {orgLine && <p class="mono" style="margin-top:1rem">{orgLine}</p>}
      </div>
      {((footer.showLinks !== false && links.length > 0) || (footer.showTowns && towns && towns.length > 0)) && (
        <div class="footer-cols">
          {footer.showLinks !== false && links.length > 0 && (
            <nav>
              <p class="mono eyebrow">{footer.linksHeading ?? 'Links'}</p>
              <ul class="footer-links">
                {links.map((l) => <li><a href={resolveLink(l.link, '/')} class="footer-link">{l.label}</a></li>)}
              </ul>
            </nav>
          )}
          {footer.showTowns && towns && towns.length > 0 && (
            <nav>
              <p class="mono eyebrow">{footer.townsHeading ?? 'Areas'}</p>
              <ul class="footer-links footer-towns">
                {towns.map((t) => <li><a href={`${townsHref ?? '/areas'}/${t.id}`} class="footer-link">{t.name}</a></li>)}
              </ul>
            </nav>
          )}
        </div>
      )}
    </div>
    <div class="footer-bar">
      <p class="mono" style="margin:0">© {contact.founded ? `${contact.founded}–` : ''}{year} {settings.name}{footer.note ? ` · ${footer.note}` : ''}</p>
      {legal.length > 0 && (
        <ul class="footer-legal">
          {legal.map((l) => <li><a href={resolveLink(l.link, '/')} class="footer-link">{l.label}</a></li>)}
        </ul>
      )}
    </div>
  </div>
</footer>
