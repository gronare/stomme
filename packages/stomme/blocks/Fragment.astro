---
import Emph from '../src/Emph.astro';
import { resolveButton } from '../src/href';

// Editorial story fragment — a big lead line, a short body and an optional quiet link,
// placed left / right / indented so consecutive fragments drift across the page
// (asymmetry as a layout tool; whitespace does the narration).
interface Props {
  eyebrow?: string;
  statement?: string;
  body?: string;
  cta?: { label?: string; link?: unknown };
  // Legacy flat pair (pre-group content) — still rendered via resolveButton fallback.
  linkLabel?: string;
  link?: unknown;
  layout?: { placement?: 'left' | 'right' | 'indent' };
}
const { eyebrow, statement, body, cta, linkLabel, link } = Astro.props;
const placement = Astro.props.layout?.placement ?? 'left';
const btn = resolveButton(cta, linkLabel, link);
---

{(statement || body) && (
  <section class="section">
    <div class:list={['fragment', `fragment--${placement}`]}>
      {eyebrow && <span class="mono eyebrow fragment__eyebrow">{eyebrow}</span>}
      {statement && <p class="display fragment__statement"><Emph text={statement} /></p>}
      {body && <p class="fragment__body">{body}</p>}
      {btn && <p class="fragment__link"><a href={btn.href} class="btn-ghost">{btn.label} →</a></p>}
    </div>
  </section>
)}
