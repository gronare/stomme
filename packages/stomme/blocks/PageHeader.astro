---
import { getEntry } from 'astro:content';
import { resolveButton } from '../src/href';
import ContactLink from '../ContactLink.astro';
import Emph from '../src/Emph.astro';

// Generic page header for prose pages. `light` = plain header; `dark` = a
// band/glow hero with CTA + phone (good for a landing/service page top).
// Reads phone from the `contact` collection; editor supplies copy + optional CTA.
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  cta?: { label?: string; link?: unknown };
  // Legacy flat pair (pre-group content) — still rendered via resolveButton fallback.
  ctaLabel?: string;
  ctaHref?: unknown;
  layout?: { variant?: 'light' | 'dark'; width?: 'narrow' | 'full' };
}
const { eyebrow, heading, intro, cta, ctaLabel, ctaHref } = Astro.props;
const variant = Astro.props.layout?.variant ?? 'light';
const width = Astro.props.layout?.width ?? 'narrow';
const read = width !== 'full';
const btn = resolveButton(cta, ctaLabel, ctaHref);
const contact = ((await getEntry('contact', 'contact').catch(() => null))?.data ?? {}) as any;
---

{variant === 'dark' ? (
  <section class="band page-header page-header--dark">
    <div class="page-header__glow" aria-hidden="true"></div>
    <div class:list={['section', 'page-header__inner', { 'section--read': read }]}>
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      <h1 class="display display--hero page-header__heading"><Emph text={heading} /></h1>
      {intro && <p class="intro page-header__intro">{intro}</p>}
      {btn && (
        <div class="btn-row">
          <a href={btn.href} class="btn btn-on-dark">{btn.label}</a>
          {contact.phone && <ContactLink kind="tel" class="btn-ghost" target={contact.phoneE164 || contact.phone} display={contact.phone} prefix="Call " suffix=" →" protect={!!contact.protectContact} />}
        </div>
      )}
    </div>
  </section>
) : (
  <section class:list={['section', 'page-header', 'page-header--light', { 'section--read': read }]}>
    {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
    <h1 class="display display--hero page-header__heading"><Emph text={heading} /></h1>
    {intro && <p class="intro page-header__intro">{intro}</p>}
    {btn && <div class="btn-row"><a href={btn.href} class="btn">{btn.label}</a></div>}
  </section>
)}
