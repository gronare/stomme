---
import { getEntry } from 'astro:content';
import { resolveLink } from '../src/href';

// Generic page header for prose pages. `light` = plain header; `dark` = a
// band/glow hero with CTA + phone (good for a landing/service page top).
// Reads phone from the `contact` collection; editor supplies copy + optional CTA.
interface Props {
  variant?: 'light' | 'dark';
  width?: 'narrow' | 'full';
  eyebrow?: string;
  heading?: string;
  intro?: string;
  ctaLabel?: string;
  ctaHref?: unknown;
}
const { variant = 'light', width = 'narrow', eyebrow, heading, intro, ctaLabel, ctaHref } = Astro.props;
const read = width !== 'full';
const href = resolveLink(ctaHref, '/');
const contact = ((await getEntry('contact', 'contact').catch(() => null))?.data ?? {}) as any;
---

{variant === 'dark' ? (
  <section class="band page-header page-header--dark">
    <div class="page-header__glow" aria-hidden="true"></div>
    <div class:list={['section', 'page-header__inner', { 'section--read': read }]}>
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      <h1 class="display display--hero page-header__heading">{heading}</h1>
      {intro && <p class="intro page-header__intro">{intro}</p>}
      {ctaLabel && (
        <div class="btn-row">
          <a href={href} class="btn btn-on-dark">{ctaLabel}</a>
          {contact.phone && <a href={`tel:${contact.phoneE164}`} class="btn-ghost">Call {contact.phone} →</a>}
        </div>
      )}
    </div>
  </section>
) : (
  <section class:list={['section', 'page-header', 'page-header--light', { 'section--read': read }]}>
    {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
    <h1 class="display display--hero page-header__heading">{heading}</h1>
    {intro && <p class="intro page-header__intro">{intro}</p>}
    {ctaLabel && <div class="btn-row"><a href={href} class="btn">{ctaLabel}</a></div>}
  </section>
)}
