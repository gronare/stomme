---
import { getEntry, getCollection } from 'astro:content';
import { resolveLink } from '../src/href';
import { inlineLocalSvg } from '../src/inline-svg';
import Cover from '../src/Cover.astro';

// Themeable site chrome (header). Reads the `navigation` + `settings` collections
// by default, but accepts `nav`/`settings` as optional props so a draft can be
// injected (e.g. the CMS live preview). A site that wants bespoke chrome can stop
// importing this and render its own .site-header markup. The logo is an uploaded
// image when `logo.image` is set, otherwise the two-tone text mark.
//
// A nav item becomes a dropdown when it has `menu` (auto: "<collectionId>::<routeBase>"
// — lists every entry, linked to its detail page) or manual `children`.
interface NavLink { label: string; link?: unknown }
interface NavItem extends NavLink { menu?: string; children?: NavLink[] }
interface NavData {
  logo?: { textPre?: string; textAccent?: string; image?: string; alt?: string };
  items?: NavItem[];
  cta?: { label: string; link?: unknown };
  sticky?: boolean;
}
interface Props { nav?: NavData; settings?: { name?: string } }

let { nav, settings } = Astro.props;
if (!nav) nav = (await getEntry('navigation', 'nav'))!.data as NavData;
if (!settings) settings = (await getEntry('settings', 'site'))!.data as { name?: string };

const logo = nav.logo ?? {};
// A local .svg logo is inlined so a currentColor wordmark tints to the header;
// other logos render as an <img>.
const logoSvg = inlineLocalSvg(logo.image);
const items = nav.items ?? [];
const homeHref = '/';

// Resolve an item's dropdown children: auto from a collection, or manual links.
async function childrenOf(item: NavItem): Promise<{ label: string; href: string }[]> {
  if (item.menu) {
    const [id, base] = String(item.menu).split('::');
    try {
      const entries = await getCollection(id as any);
      entries.sort((a: any, b: any) => {
        const da = a.data.date, db = b.data.date;
        if (da && db) return da < db ? 1 : -1;
        return String(a.data.navLabel ?? a.data.title ?? a.id).localeCompare(String(b.data.navLabel ?? b.data.title ?? b.id));
      });
      return entries.map((e: any) => ({ label: e.data.navLabel ?? e.data.title ?? e.id, href: `${base}/${e.id}` }));
    } catch { return []; }
  }
  if (Array.isArray(item.children)) return item.children.map((c) => ({ label: c.label, href: resolveLink(c.link, homeHref) }));
  return [];
}
// Empty href (not the home fallback) marks a dropdown-only header — a parent that
// just opens its menu and links nowhere.
const resolved = await Promise.all(
  items.map(async (i) => ({ label: i.label, href: resolveLink(i.link, ''), children: await childrenOf(i) })),
);
---
<header class:list={['site-header', { 'is-sticky': nav.sticky }]}>
  <div class="inner">
    <a class="logo" href={homeHref} aria-label={settings.name}>
      {logoSvg
        ? <span class="logo-lockup" set:html={logoSvg} />
        : logo.image
        ? <Cover src={logo.image} alt={logo.alt ?? settings.name} placeholder="/images/placeholder.svg" class="logo-img" />
        : <Fragment>{logo.textPre ?? settings.name}<span class="accent">{logo.textAccent}</span></Fragment>}
    </a>
    <nav class="site-nav" id="site-nav">
      {resolved.map((i) => i.children.length ? (
        <div class="nav-item nav-item--menu">
          {i.href
            ? <a class="nav-top" href={i.href} aria-haspopup="true">{i.label}</a>
            : <span class="nav-top" role="button" tabindex="0" aria-haspopup="true">{i.label}</span>}
          <button class="nav-caret-btn" type="button" aria-label="Show submenu" aria-expanded="false"><span class="nav-caret" aria-hidden="true"></span></button>
          <ul class="nav-submenu">
            {i.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
          </ul>
        </div>
      ) : (
        <a href={i.href || homeHref}>{i.label}</a>
      ))}
    </nav>
    {nav.cta && <a class="btn site-cta" href={resolveLink(nav.cta.link, homeHref)}>{nav.cta.label}</a>}
    <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
      <span class="nav-toggle__bars" aria-hidden="true"></span>
    </button>
  </div>
</header>
<script is:inline>
  (function () {
    var header = document.querySelector('.site-header');
    if (!header) return;
    var toggle = header.querySelector('.nav-toggle');
    var mobile = window.matchMedia('(max-width: 820px)');

    // Desktop dropdowns open on hover/focus (CSS); a click would otherwise pin them
    // open via :focus-within, so blur on click. On mobile the caret button is the
    // accordion toggle (expand its items), while the label link navigates as normal —
    // a link-less header has nothing to navigate to, so tapping its label expands too.
    header.querySelectorAll('.nav-item--menu').forEach(function (item) {
      var top = item.querySelector('.nav-top');
      var caret = item.querySelector('.nav-caret-btn');
      var expand = function () {
        var open = !item.classList.contains('is-open');
        item.classList.toggle('is-open', open);
        if (caret) caret.setAttribute('aria-expanded', open ? 'true' : 'false');
      };
      if (caret) caret.addEventListener('click', function () { if (mobile.matches) expand(); caret.blur(); });
      if (top) top.addEventListener('click', function (e) {
        if (mobile.matches && top.tagName === 'SPAN') { e.preventDefault(); expand(); }
        else { top.blur(); }
      });
    });

    // Mobile fold-out panel: the hamburger toggles it; tapping a real destination
    // (leaf link or the CTA — not an accordion header) closes it.
    if (toggle) {
      var setOpen = function (open) {
        header.classList.toggle('nav-open', open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      };
      toggle.addEventListener('click', function () { setOpen(!header.classList.contains('nav-open')); });
      header.querySelectorAll('.site-nav a[href]:not(.nav-top), .site-cta').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
    }

    // Transparent overlay header: when the page opens with a full-bleed hero (a cover,
    // or a hero with a Dark/Gradient surface) the header is styled transparent via CSS
    // :has. A non-sticky header is positioned over the hero and simply scrolls away with
    // it (no JS needed). Only a *sticky* header stays put, so only then do we turn it
    // solid — just before the hero's text would scroll under it, so the logo/nav never
    // overlap the heading. Runs before <main> is parsed, so defer until DOM ready.
    var initOverlay = function () {
      if (!header.classList.contains('is-sticky')) return;
      var cover = document.querySelector('main .cover:first-child');
      var darkHero = document.querySelector('main .surface-dark:first-child .hero-grid, main .surface-gradient:first-child .hero-grid');
      var hero = cover || (darkHero && darkHero.closest('.surface-dark, .surface-gradient'));
      if (!hero) return;
      var inner = hero.querySelector('.cover__inner, .hero-grid');
      var trigger = 0;
      var measure = function () {
        var headerH = header.offsetHeight || 64;
        var top = inner ? inner.getBoundingClientRect().top + window.scrollY : hero.offsetHeight * 0.5;
        trigger = Math.max(0, top - headerH - 16);
      };
      var onScroll = function () { header.classList.toggle('solid', window.scrollY > trigger); };
      measure(); onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', function () { measure(); onScroll(); }, { passive: true });
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initOverlay);
    else initOverlay();
  })();
</script>
