---
import { getCollection } from 'astro:content';
import Cover from '../src/Cover.astro';

// Collection-backed blog index — a featured lead card (newest post) + a grid of cards
// with cover images. The section head is optional (pair with a pageHeader, or set its
// own eyebrow/heading). Needs a `posts` collection (title, date, excerpt, cover).
//
// Route prefix, date locale and the "read more" string come from the site config
// (`site`, forwarded by BlockRenderer); the prefix must match the route under src/pages/.
// `items` is a fixture override (lookbook samples) — not a CMS field. When given,
// the collection is never queried; live pages always take the collection path.
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  showImages?: boolean;
  featured?: boolean;
  columns?: number;
  source?: string;
  base?: string;
  items?: { id: string; data: Record<string, any> }[];
  site?: any;
}
const { eyebrow, heading, intro, showImages = false, featured = false, columns = 3, source = 'posts', base, site } = Astro.props;
const prefix = base ?? site?.routes?.blog ?? '/blog';
const locale = site?.locale ?? 'en-US';
const readMore = site?.strings?.readMore ?? 'Read more';
const latest = site?.strings?.latest ?? 'Latest';
const all = Astro.props.items ?? (await getCollection(source)).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
const fmt = (d: string) => new Date(d).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
const lead = featured && all.length > 1 ? all[0] : null;
const rest = lead ? all.slice(1) : all;
const PLACE = '/images/placeholders/service.svg';
// Show a cover when the post opts in (showCover): its uploaded image, or the brand-tinted
// default if none. Otherwise the card is text-only. The index mixes both kinds cleanly.
const leadHasImg = !!(lead && showImages && lead.data.showCover);
const hasImg = (p: any) => !!(showImages && p.data.showCover);
---
{all.length > 0 && (
  <section class="section">
    {(eyebrow || heading || intro) && (
      <div class="section-head post-head">
        {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
        {heading && <h2 class="display" style="margin-top:0.75rem">{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}
    {lead && (
      <a href={`${prefix}/${lead.id}`} class:list={['post-feature', { 'post-feature--text': !leadHasImg }]}>
        <span class="post-latest">{latest}</span>
        {leadHasImg && (
          <Cover src={lead.data.cover} alt={lead.data.title} placeholder={PLACE} width={1000} height={640} class="post-feature__img" />
        )}
        <div class="post-feature__body">
          <p class="mono">{fmt(lead.data.date)}</p>
          <h3 class="post-feature__title">{lead.data.title}</h3>
          {lead.data.excerpt && <p class="post-excerpt">{lead.data.excerpt}</p>}
          <span class="mono post-more">{readMore} →</span>
        </div>
      </a>
    )}
    {rest.length > 0 && (
      <div class="post-grid" style={`--post-cols:${columns}`}>
        {rest.map((p) => (
          <a href={`${prefix}/${p.id}`} class="post-card">
            {hasImg(p) && (
              <Cover src={p.data.cover} alt={p.data.title} placeholder={PLACE} width={800} height={480} class="post-card__img" />
            )}
            <div class="post-card__body">
              <p class="mono">{fmt(p.data.date)}</p>
              <h3 class="post-title">{p.data.title}</h3>
              {p.data.excerpt && <p class="post-excerpt">{p.data.excerpt}</p>}
              <span class="mono post-more">{readMore} →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
)}
