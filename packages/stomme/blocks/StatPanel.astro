---
import Emph from '../src/Emph.astro';

// A bold, dark "statement + headline number" panel — a message (eyebrow / heading /
// body) and a row of badge pills on one side, a single giant stat on the other.
// Generic version of a trust/safety beat; all copy is editable. Always dark
// (uses --color-ink + --color-on-dark) regardless of surface, for contrast.
interface Stat { label?: string; value?: string; note?: string }
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  badges?: string[];
  statValue?: string;
  statLabel?: string;
  stats?: Stat[];
  accent?: 'brand' | 'secondary' | 'highlight';
}
const { eyebrow, heading, body, badges = [], statValue, statLabel, stats = [], accent = 'brand' } = Astro.props;
const accentVar = accent === 'secondary' ? 'var(--color-secondary)' : accent === 'highlight' ? 'var(--color-highlight)' : 'var(--color-brand)';
---
<section class="stat-panel" style={`--block-accent:${accentVar}`}>
  <div class="stat-panel__inner">
    <div class="stat-panel__main">
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      {heading && <h2 class="display stat-panel__h"><Emph text={heading} /></h2>}
      {body && <p class="stat-panel__body">{body}</p>}
      {badges.length > 0 && (
        <div class="stat-panel__badges">
          {badges.map((b) => <span class="stat-panel__pill">{b}</span>)}
        </div>
      )}
      {stats.length > 0 && (
        <div class="stat-panel__cols">
          {stats.map((s) => (
            <div class="stat-panel__col">
              {s.label && <span class="mono stat-panel__col-label">{s.label}</span>}
              {s.value && <span class="stat-panel__col-value">{s.value}</span>}
              {s.note && <p class="stat-panel__col-note">{s.note}</p>}
            </div>
          ))}
        </div>
      )}
    </div>
    {stats.length === 0 && statValue && (
      <div class="stat-panel__stat">
        <span class="stat-panel__value">{statValue}</span>
        {statLabel && <span class="mono">{statLabel}</span>}
      </div>
    )}
  </div>
</section>
