---
import Emph from '../src/Emph.astro';

// Pull-quote / standout statement to break up body text. A coloured left rule and
// an oversized display quote. `accent` picks which token the rule + eyebrow marker use.
// `width` sizes the quote column (narrow reads best; extra narrow for short punchlines;
// full spans the section) and `align` places the column in the section.
interface Props {
  eyebrow?: string;
  quote?: string;
  layout?: { width?: 'narrow' | 'xnarrow' | 'full'; align?: 'left' | 'center' | 'right' };
  style?: { surface?: string; accent?: 'brand' | 'secondary' | 'highlight' };
}
const { eyebrow, quote } = Astro.props;
const width = Astro.props.layout?.width ?? 'narrow';
const align = Astro.props.layout?.align ?? 'left';
const accent = Astro.props.style?.accent ?? 'brand';
const accentVar = accent === 'secondary' ? 'var(--color-secondary)' : accent === 'highlight' ? 'var(--color-highlight)' : 'var(--color-brand)';
---

{quote && (
  <section class:list={['section', { 'section--read': width === 'narrow' }]}>
    {/* narrow constrains the SECTION (identical box to a narrow hero); xnarrow/full size the figure */}
    <figure class:list={['callout', `callout--${width}`, `callout--${align}`]} style={`--block-accent:${accentVar}`}>
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      <blockquote class="display callout__quote"><Emph text={quote} /></blockquote>
    </figure>
  </section>
)}
