---
// "Find us" — a larger section: a map beside the address, contact and hours, all
// auto-filled from the Contact settings. The map needs lat/lng on the address.
// `data` overrides the settings lookup so the CMS preview can render a draft.
import { getEntry } from 'astro:content';
import ContactLink from '../ContactLink.astro';
interface Props { heading?: string; showHours?: boolean; data?: any }
const { heading = 'Find us', showHours, data } = Astro.props;
const c = (data ?? (await getEntry('contact', 'contact').catch(() => null))?.data ?? {}) as any;
const protect = !!c.protectContact;
const a = c.address ?? {};
const hasMap = a.lat != null && a.lng != null;
const d = 0.006;
const mapSrc = hasMap
  ? `https://www.openstreetmap.org/export/embed.html?bbox=${a.lng - d}%2C${a.lat - d}%2C${a.lng + d}%2C${a.lat + d}&layer=mapnik&marker=${a.lat}%2C${a.lng}`
  : '';
const cityLine = [a.postcode, a.city].filter(Boolean).join(' ');
const hasAddr = !!(a.street || cityLine || a.country);
const hours = (c.hours ?? []) as { days: string; hours: string }[];
const hoursNote = c.hoursNote ?? '';
const showHrs = showHours !== false;
---
<section class="findus-block">
  <div class="findus">
    {hasMap && (
      <div class="findus__map">
        <iframe src={mapSrc} loading="lazy" title="Map" referrerpolicy="no-referrer-when-downgrade"></iframe>
        <p class="findus__attrib">© <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a></p>
      </div>
    )}
    <div class:list={['findus__info', !hasMap && 'findus__info--solo']}>
      {heading && <h2 class="findus__h">{heading}</h2>}
      {hasAddr && (
        <p class="findus__addr">{a.street}{a.street && <br />}{cityLine}{cityLine && <br />}{a.country}</p>
      )}
      {(c.phone || c.email) && (
        <p class="findus__reach">
          {c.phone && <ContactLink kind="tel" class="findus__phone" target={c.phoneE164 || c.phone} display={c.phone} protect={protect} />}
          {c.email && <ContactLink kind="mailto" class="findus__email" target={c.email} display={c.email} protect={protect} />}
        </p>
      )}
      {showHrs && hours.length > 0 && (
        <div class="direct-card__hours findus__hours">{hours.map((h: any) => (
          <div class="direct-card__hrow">
            <span class="direct-card__days">{h.days}</span>
            <span class="direct-card__hval">{h.hours}</span>
          </div>
        ))}</div>
      )}
      {showHrs && hoursNote && <p class="direct-card__hnote">{hoursNote}</p>}
    </div>
  </div>
</section>
