---
import { getEntry } from 'astro:content';
import { resolveButton } from '../src/href';
import Cover from '../src/Cover.astro';
// The animated background is inlined (not <img>) so its currentColor tints to the brand.
import motionSvg from '../assets/images/placeholders/motion.svg?raw';

// Full-bleed cover banner — a background photo or a muted looping video with
// overlaid heading, intro and up to two buttons. The image always renders
// behind the video, so it doubles as the poster / reduced-motion fallback
// (the video is hidden under prefers-reduced-motion). Generic by design — no
// domain-specific media, unlike the hero's flow/ops panels.
// Grouped fields (block-field convention): `media` holds the background kind picker
// (`kind`) + its assets and the darkening overlay; `layout` holds placement.
interface Props {
  eyebrow?: string;
  heading: string;
  intro?: string;
  cta?: { label?: string; link?: unknown };
  cta2?: { label?: string; link?: unknown };
  // Legacy flat pair (pre-group content) — still rendered via resolveButton fallback.
  ctaLabel?: string;
  ctaHref?: unknown;
  cta2Label?: string;
  cta2Href?: unknown;
  media?: {
    kind?: 'image' | 'video' | 'gradient' | 'animated';
    image?: string;
    imageAlt?: string;
    video?: string;
    videoUrl?: string;
    overlay?: 'light' | 'medium' | 'strong';
  };
  layout?: { align?: 'start' | 'center'; height?: 'tall' | 'medium' };
}
const { eyebrow, heading, intro, cta, cta2, ctaLabel, ctaHref, cta2Label, cta2Href } = Astro.props;
const media = Astro.props.media?.kind ?? 'image';
const image = Astro.props.media?.image;
const imageAlt = Astro.props.media?.imageAlt;
const video = Astro.props.media?.video;
const videoUrl = Astro.props.media?.videoUrl;
const overlay = Astro.props.media?.overlay ?? 'medium';
const align = Astro.props.layout?.align ?? 'start';
const height = Astro.props.layout?.height ?? 'tall';

const btn = resolveButton(cta, ctaLabel, ctaHref);
const btn2 = resolveButton(cta2, cta2Label, cta2Href);

// Resolve an uploaded video to a hashed served URL; external URLs win.
const videoFiles = import.meta.glob('/src/assets/media/**/*.{mp4,webm,mov}', {
  query: '?url', import: 'default', eager: true,
});
const videoKey = video && video.startsWith('/media/') ? `/src/assets/media/${video.slice('/media/'.length)}` : null;
const videoSrc =
  media === 'video'
    ? (videoUrl || (videoKey && (videoFiles as Record<string, string>)[videoKey]) || video || undefined)
    : undefined;
---
<section class:list={['cover', `cover--${align}`, `cover--h-${height}`, `cover--ov-${overlay}`]}>
  <div class:list={['cover__media', { 'cover__media--gradient': media === 'gradient' || media === 'animated' }]}>
    {media !== 'gradient' && media !== 'animated' && (
      <Cover
        src={image}
        alt={imageAlt ?? heading}
        placeholder="/images/placeholder.svg"
        width={1600}
        height={900}
        loading="eager"
        class="cover__img"
      />
    )}
    {media === 'animated' && <div class="cover__motion" aria-hidden="true" set:html={motionSvg} />}
    {videoSrc && (
      <video class="cover__video" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
        <source src={videoSrc} />
      </video>
    )}
  </div>
  <div class="cover__scrim" aria-hidden="true"></div>
  <div class="cover__inner">
    {eyebrow && <span class="cover__eyebrow">{eyebrow}</span>}
    <h1 class="cover__h1">{String(heading).split('\n').map((line, i) => i === 0 ? line : <Fragment><br />{line}</Fragment>)}</h1>
    {intro && <p class="cover__intro">{intro}</p>}
    {(btn || btn2) && (
      <div class="cover__cta">
        {btn && <a href={btn.href} class="btn">{btn.label}</a>}
        {btn2 && <a href={btn2.href} class="btn cover__btn-ghost">{btn2.label}</a>}
      </div>
    )}
  </div>
</section>
