---
import { getEntry } from 'astro:content';
import { resolveLink } from '../src/href';
import Cover from '../src/Cover.astro';
import Icon from '../src/Icon.astro';

// Library hero: a universal left column + a swappable, generic media slot:
//   none        — text only
//   image       — a picture beside the heading
//   highlights   — an editable list of icon + title + line (key points / selling points)
//   motif       — a decorative, theme-tinted block animation (no content)
// Domain-specific media (e.g. an energy-flow diagram or a drone scene) live in the
// consuming site as a custom hero registered over this one — see docs/customizing.md.
interface Highlight { icon?: string; title: string; body?: string }
interface Props {
  eyebrow?: string;
  heading: string;
  intro?: string;
  ctaLabel?: string;
  ctaHref?: unknown;
  media?: 'none' | 'image' | 'highlights' | 'motif';
  image?: string;
  imageAlt?: string;
  highlights?: Highlight[];
  height?: 'normal' | 'tall';
  align?: 'top' | 'center' | 'bottom';
}
const { eyebrow, heading, intro, ctaLabel, ctaHref, media = 'none', image, imageAlt, highlights = [], height = 'normal', align = 'center' } = Astro.props;
const href = resolveLink(ctaHref, '/');
const contact = ((await getEntry('contact', 'contact').catch(() => null))?.data ?? {}) as any;
const showImage = media === 'image' && !!image;
const showHighlights = media === 'highlights' && highlights.length > 0;
const showMotif = media === 'motif';
const hasMedia = showImage || showHighlights || showMotif;
---
<section class:list={['section', { 'section--hero-tall': height === 'tall' }, height === 'tall' && `section--hero-${align}`]}>
  <div class:list={['hero-grid', { 'has-media': hasMedia }]}>
    <div>
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      <h1 class="display display--hero" style="margin-top:1rem">{heading}</h1>
      {intro && <p class="intro">{intro}</p>}
      {(ctaLabel || contact.phone) && (
        <div class="btn-row">
          {ctaLabel && <a href={href} class="btn">{ctaLabel}</a>}
          {contact.phone && <a href={`tel:${contact.phoneE164}`} class="btn-ghost">{contact.phone} →</a>}
        </div>
      )}
    </div>

    {showImage && (
      <div class="hero-media">
        <Cover src={image} alt={imageAlt ?? heading} placeholder="/images/placeholder.svg" width={1000} height={750} class="hero-img" />
      </div>
    )}

    {showHighlights && (
      <ul class="hero-highlights">
        {highlights.map((h) => (
          <li class="hl-row">
            <span class="hl-ic"><Icon name={h.icon} /></span>
            <div>
              <div class="hl-t">{h.title}</div>
              {h.body && <div class="hl-d">{h.body}</div>}
            </div>
          </li>
        ))}
      </ul>
    )}

    {showMotif && (
      <div class="hero-motif" aria-hidden="true">
        <svg viewBox="0 0 320 260" role="img" aria-label="">
          <line x1="40" y1="206" x2="280" y2="206" stroke="currentColor" stroke-width="2.5" opacity=".3" />
          <rect class="hm-rise hm-d1" x="52" y="124" width="36" height="82" rx="9" opacity=".5" />
          <rect class="hm-rise hm-d2" x="104" y="78" width="42" height="128" rx="10" opacity="1" />
          <rect class="hm-rise hm-d3" x="162" y="148" width="36" height="58" rx="9" opacity=".22" />
          <rect class="hm-rise hm-d4" x="214" y="108" width="38" height="98" rx="9" opacity=".5" />
          <rect class="hm-rise hm-d5" x="266" y="138" width="14" height="68" rx="7" opacity=".5" />
          <rect class="hm-float" x="214" y="44" width="46" height="32" rx="9" opacity=".85" />
          <circle cx="125" cy="78" r="4" />
        </svg>
      </div>
    )}
  </div>
</section>
