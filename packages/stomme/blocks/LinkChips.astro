---
import { getCollection } from 'astro:content';

// Collection-backed (the `towns` collection) with editable chrome. The section
// head renders only when given; CMS defaults pre-fill a new block. Needs a
// `towns` collection in the consuming site (fields: name, order). The detail-page
// route prefix comes from the site config (`site.routes.towns`, forwarded by
// BlockRenderer) and must match the actual route folder under src/pages/.
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  site?: any;
}
const { eyebrow, heading, intro, site } = Astro.props;
const prefix = site?.routes?.towns ?? '/areas';
const towns = (await getCollection('towns')).sort((a, b) => a.data.order - b.data.order);
---
<section class="section">
  {(eyebrow || heading || intro) && (
    <div class="section-head">
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      {heading && <h2 class="display" style="margin-top:0.75rem">{heading}</h2>}
      {intro && <p class="intro">{intro}</p>}
    </div>
  )}
  <div class="link-chip-row">
    {towns.map((t) => <a href={`${prefix}/${t.id}`} class="link-chip">{t.data.name}</a>)}
  </div>
</section>
