---
import Emph from '../src/Emph.astro';
import Icon from '../src/Icon.astro';
import { resolveLink } from '../src/href';

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  items?: { icon?: string; title: string; body?: string; tag?: string; link?: unknown; linkLabel?: string }[];
  numbered?: boolean;
  accent?: 'brand' | 'secondary' | 'highlight';
  site?: any;
}
const { eyebrow, heading, intro, items = [], numbered = false, accent = 'brand', site } = Astro.props;
const readMore = site?.strings?.readMore ?? 'Read more';
const accentVar = accent === 'secondary' ? 'var(--color-secondary)' : accent === 'highlight' ? 'var(--color-highlight)' : 'var(--color-brand)';
---
<section class="section" style={`--block-accent:${accentVar}`}>
  {(eyebrow || heading || intro) && (
    <div class="section-head">
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      {heading && <h2 class="display" style="margin-top:0.75rem"><Emph text={heading} /></h2>}
      {intro && <p class="intro">{intro}</p>}
    </div>
  )}
  <div class="feature-grid">
    {items.map((it, i) => {
      const href = it.link ? resolveLink(it.link, '') : '';
      const Tag = href ? 'a' : 'div';
      return (
        <Tag href={href || undefined} class="card feature-card">
          {numbered ? (
            <span class="mono" style="color:var(--block-accent, var(--color-brand))">{`0${i + 1}`}</span>
          ) : (
            it.icon && <span class="ico-badge"><Icon name={it.icon} /></span>
          )}
          <h3>{it.title}</h3>
          {it.body && <p>{it.body}</p>}
          {href && <span class="mono" style="display:inline-block;margin-top:1rem;color:var(--color-brand)">{it.linkLabel ?? readMore} →</span>}
          {it.tag && <span class="mono card-tag">{it.tag}</span>}
        </Tag>
      );
    })}
  </div>
</section>
