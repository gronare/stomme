---
import { renderMarkdown } from '../src/markdown';

// Two-up: body text beside a quotation. The quote isn't meant to stand alone — it
// accents the body text next to it. Text gets the wider column; the quote is
// vertically centred. `flip` puts the quote on the left.
interface Props {
  body?: string;
  quote?: string;
  attribution?: string;
  layout?: { flip?: boolean };
  style?: { surface?: string; accent?: 'brand' | 'secondary' | 'highlight' };
}
const { body = '', quote, attribution } = Astro.props;
const flip = Astro.props.layout?.flip ?? false;
const accent = Astro.props.style?.accent ?? 'brand';
const accentVar = accent === 'secondary' ? 'var(--color-secondary)' : accent === 'highlight' ? 'var(--color-highlight)' : 'var(--color-brand)';
const html = await renderMarkdown(body);
---

<section class="section">
  <div class:list={['tq-grid', { 'tq-flip': flip }]}>
    <div class:list={['prose', 'tq-body', { 'tq-second': flip }]} set:html={html} />
    {quote && (
      <figure class:list={['tq-quote', { 'tq-first': flip }]} style={`--block-accent:${accentVar}`}>
        <blockquote class="display tq-text">{quote}</blockquote>
        {attribution && <figcaption class="mono tq-attr">{attribution}</figcaption>}
      </figure>
    )}
  </div>
</section>
