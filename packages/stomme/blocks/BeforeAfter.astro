---
import Cover from '../src/Cover.astro';
// Default art (no images set): the structural wireframe→built pair, inlined so its
// currentColor tints to the brand. Uploaded before/after images render via Cover.
import beforeArt from '../assets/images/placeholders/before.svg?raw';
import afterArt from '../assets/images/placeholders/after.svg?raw';

// Before / after slider — drag (or use the keyboard-accessible range input) to
// wipe between two images via a CSS clip driven by a custom property. The section
// chrome (eyebrow/heading/intro) wraps the bespoke slider previously kept in a
// separate BeforeAfter component — inlined here so the block is self-contained.
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  media?: { before?: string; after?: string };
  beforeAlt?: string;
  afterAlt?: string;
  site?: any;
}
const { eyebrow, heading, intro, site } = Astro.props;
const before = Astro.props.media?.before;
const after = Astro.props.media?.after;
const ba = site?.strings?.beforeAfter ?? {};
const tagBefore = ba.before ?? 'Before';
const tagAfter = ba.after ?? 'After';
const beforeAlt = Astro.props.beforeAlt ?? tagBefore;
const afterAlt = Astro.props.afterAlt ?? tagAfter;
---

<section class="section">
  {(eyebrow || heading || intro) && (
    <div class="section-head">
      {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
      {heading && <h2 class="display" style="margin-top:0.75rem">{heading}</h2>}
      {intro && <p class="intro">{intro}</p>}
    </div>
  )}
  <figure class="ba">
    {after
      ? <Cover src={after} alt={afterAlt} placeholder="/images/placeholders/after.svg" width={1200} height={750} class="ba-img" />
      : <div class="ba-img ba-art" set:html={afterArt} />}
    <div class="ba-clip">
      {before
        ? <Cover src={before} alt={beforeAlt} placeholder="/images/placeholders/before.svg" width={1200} height={750} class="ba-img" />
        : <div class="ba-img ba-art" set:html={beforeArt} />}
    </div>
    <div class="ba-line" aria-hidden="true"><span class="ba-handle">⇄</span></div>
    <span class="ba-tag ba-tag-before" aria-hidden="true">{tagBefore}</span>
    <span class="ba-tag ba-tag-after" aria-hidden="true">{tagAfter}</span>
    <input class="ba-range" type="range" min="0" max="100" value="50"
      aria-label="Drag to compare before and after" />
  </figure>
</section>
<script>
  document.querySelectorAll('.ba').forEach((el) => {
    const node = el as HTMLElement;
    const range = node.querySelector('.ba-range') as HTMLInputElement | null;
    const set = (v: string) => node.style.setProperty('--pos', v + '%');
    range?.addEventListener('input', (e) => set((e.target as HTMLInputElement).value));
  });
</script>
