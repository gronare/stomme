---
import { getCollection } from 'astro:content';
import Cover from '../src/Cover.astro';
import { resolveListings, listingSpecRows } from '../src/config';

// Catalog index for a `catalog` listing (for-sale items). Reads the listing's collection
// (`source`) and renders a filterable card grid: cover + status badge, price, a few specs.
// `base` is the detail-link prefix (the listing route). Newest first. Category filtering
// is client-side. Status labels come from site.strings.listingStatus (English default).
// `items` is a fixture override (lookbook samples) — not a CMS field. When given,
// the collection is never queried; live pages always take the collection path.
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  source?: string;
  base?: string;
  media?: { showImages?: boolean };
  layout?: { filters?: boolean; columns?: number };
  items?: { id: string; data: Record<string, any> }[];
  site?: any;
}
const { eyebrow, heading, intro, source = '', base, site } = Astro.props;
const showImages = Astro.props.media?.showImages ?? false;
const filters = Astro.props.layout?.filters ?? false;
const columns = Astro.props.layout?.columns ?? 3;
// Item titles are h3 under a section heading, else h2 under the page h1 — no skipped
// level (see PostList). Astro renders a Capitalized string var as that HTML tag.
const ItemHeading = heading ? 'h3' : 'h2';
const prefix = base ?? (source ? `/${source}` : '');
const readMore = site?.strings?.readMore ?? 'Read more';
const sl = { available: 'Available', reserved: 'Reserved', sold: 'Sold', all: 'All', ...(site?.strings?.listingStatus || {}) };
const ST = { available: 'avail', reserved: 'res', sold: 'sold' };
const items = Astro.props.items
  ?? (source
    ? (await getCollection(source)).sort((a, b) => ((a.data.date ?? '') < (b.data.date ?? '') ? 1 : -1))
    : []);
// The listing's config-defined specs (labels) — from the site config forwarded via the
// `site` prop — paired per-item with keyed values below.
const listing = resolveListings(site?.listings).find((l) => l.id === source);
const cats = [...new Set(items.map((i) => i.data.category).filter(Boolean))];
const PLACE = '/images/placeholders/service.svg';
---
{items.length > 0 && (
  <section class="section">
    {(eyebrow || heading || intro) && (
      <div class="section-head post-head">
        {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
        {heading && <h2 class="display" style="margin-top:0.75rem">{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}
    {filters && cats.length > 1 && (
      <div class="catalog-filters" data-catalog-filters>
        <button type="button" class="catalog-chip is-on" data-cat="">{sl.all}</button>
        {cats.map((c) => (
          <button type="button" class="catalog-chip" data-cat={c}>{c}</button>
        ))}
      </div>
    )}
    <div class="catalog-grid" style={`--cat-cols:${columns}`}>
      {items.map((it) => (
        <a href={`${prefix}/${it.id}`} class={`listing-card is-${ST[it.data.status] || 'avail'}`} data-cat={it.data.category || ''}>
          {showImages && (
            <div class="listing-photo">
              <Cover src={it.data.cover} alt={it.data.title} placeholder={PLACE} width={640} height={400} class="listing-img" />
              <span class={`listing-badge b-${ST[it.data.status] || 'avail'}`}>{sl[it.data.status] || it.data.status}</span>
            </div>
          )}
          <div class="listing-body">
            <ItemHeading class="listing-title">{it.data.title}</ItemHeading>
            {it.data.price && <p class="listing-price">{it.data.price}</p>}
            {listingSpecRows(it.data, listing).length > 0 && (
              <div class="listing-specs">
                {listingSpecRows(it.data, listing).slice(0, 4).map((s) => (
                  <div class="listing-spec"><span>{s.label}</span><b>{s.value}</b></div>
                ))}
              </div>
            )}
            <span class="mono listing-more">{readMore} →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
<script>
  document.querySelectorAll('[data-catalog-filters]').forEach((bar) => {
    const grid = bar.parentElement?.querySelector('.catalog-grid');
    if (!grid) return;
    bar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.catalog-chip');
      if (!btn) return;
      bar.querySelectorAll('.catalog-chip').forEach((c) => c.classList.toggle('is-on', c === btn));
      const cat = btn.getAttribute('data-cat');
      grid.querySelectorAll('.listing-card').forEach((card) => {
        (card as HTMLElement).style.display = !cat || card.getAttribute('data-cat') === cat ? '' : 'none';
      });
    });
  });
</script>
