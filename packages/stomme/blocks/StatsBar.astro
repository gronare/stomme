---
// A label/value facts grid. The facts live on the block instance (add a Stats block
// where you want them), so different pages can show different numbers.
interface Props { items?: { label: string; value: string }[] }
const { items } = Astro.props;
const facts = Array.isArray(items) ? items : [];
---
{facts.length > 0 && (
  <section class="section">
    <dl class="facts-grid">
      {facts.map((f) => (
        <div class="fact">
          <dt class="mono">{f.label}</dt>
          <dd class="fact-value">{f.value}</dd>
        </div>
      ))}
    </dl>
  </section>
)}
