---
// Pricing / plans block — a row of plan cards (name, price, period, description,
// features, optional badge + CTA). One card can be highlighted as the default choice.
// Styling reads theme tokens, so it follows the site's palette (monochrome on a B&W theme).
import { resolveLink } from '../src/href';

interface Plan {
  name?: string;
  price?: string;
  period?: string;
  description?: string;
  features?: { text?: string }[];
  badge?: string;
  highlight?: boolean;
  ctaLabel?: string;
  ctaHref?: unknown;
}
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  plans?: Plan[];
}
const { eyebrow, heading, intro, plans = [] } = Astro.props;
---

{(heading || plans.length > 0) && (
  <section class="section">
    {(eyebrow || heading || intro) && (
      <div class="section-head">
        {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
        {heading && <h2 class="display plans__heading">{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}
    <div class="plans">
      {plans.map((p) => (
        <div class:list={['plan', { 'plan--highlight': p.highlight }]}>
          {p.name && <h3 class="plan__name">{p.name}{p.badge && <span class="plan__badge">{p.badge}</span>}</h3>}
          {!p.name && p.badge && <span class="plan__badge">{p.badge}</span>}
          {p.price && (
            <div class="plan__price">
              {p.price}
              {p.period && <span class="plan__period"> {p.period}</span>}
            </div>
          )}
          {p.description && <p class="plan__desc">{p.description}</p>}
          {p.features && p.features.length > 0 && (
            <ul class="plan__features">
              {p.features.filter((f) => f && f.text).map((f) => <li>{f.text}</li>)}
            </ul>
          )}
          {p.ctaLabel && (
            <a href={resolveLink(p.ctaHref, '/')} class="btn plan__cta">{p.ctaLabel}</a>
          )}
        </div>
      ))}
    </div>
  </section>
)}
