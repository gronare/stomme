---
import { resolveLink } from '../src/href';
import Emph from '../src/Emph.astro';

// Compact call-to-action box — a single brand-coloured panel with an eyebrow,
// heading and one button (plus an optional quiet second link, e.g. a direct email).
// Distinct from ctaPanel (which sits on a surface band); this one is always the
// brand colour with on-dark text.
interface Props {
  eyebrow?: string;
  heading: string;
  intro?: string;
  label: string;
  href?: unknown;
  label2?: string;
  href2?: unknown;
}
const { eyebrow, heading, intro, label, href, label2, href2 } = Astro.props;
const url = resolveLink(href, '/');
const url2 = resolveLink(href2, '/');
---

<section class="section">
  <div class="ctabox">
    {eyebrow && <span class="mono ctabox-eyebrow">{eyebrow}</span>}
    <h2 class="display ctabox-heading"><Emph text={heading} /></h2>
    {intro && <p class="ctabox-intro">{intro}</p>}
    <a href={url} class="ctabox-btn">{label}</a>
    {label2 && <a href={url2} class="btn-ghost ctabox-link2">{label2} →</a>}
  </div>
</section>
