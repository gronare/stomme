---
import { resolveLink } from '../src/href';
import Emph from '../src/Emph.astro';

// Compact call-to-action box. Three layouts, all theme-token driven:
//   classic — a single brand-coloured panel, centered (the default; unchanged).
//   split   — asymmetric: copy on one side, a dark facts card on the other.
//   panel   — a dark panel with the copy plus a mono key/value readout.
// `facts` (label + value) feeds the split card's chips and the panel readout;
// it is ignored by classic. Distinct from ctaPanel (which sits on a surface band).
interface Fact { label?: string; value?: string }
interface Props {
  variant?: 'classic' | 'split' | 'panel';
  eyebrow?: string;
  heading: string;
  intro?: string;
  label: string;
  href?: unknown;
  label2?: string;
  href2?: unknown;
  facts?: Fact[];
}
const { variant = 'classic', eyebrow, heading, intro, label, href, label2, href2, facts = [] } = Astro.props;
const url = resolveLink(href, '/');
const url2 = resolveLink(href2, '/');
const shownFacts = (facts ?? []).filter((f) => f && (f.label || f.value));
const hasFacts = variant !== 'classic' && shownFacts.length > 0;
---

<section class="section">
  <div class:list={['ctabox', `ctabox--${variant}`]}>
    <div class="ctabox-copy">
      {eyebrow && <span class="mono ctabox-eyebrow">{eyebrow}</span>}
      <h2 class="display ctabox-heading"><Emph text={heading} /></h2>
      {intro && <p class="ctabox-intro">{intro}</p>}
      <a href={url} class="ctabox-btn">{label}</a>
      {label2 && <a href={url2} class="btn-ghost ctabox-link2">{label2} →</a>}
    </div>

    {hasFacts && variant === 'split' && (
      <ul class="ctabox-aside" aria-hidden="true">
        {shownFacts.map((f) => (
          <li class="ctabox-chip">{f.label && <span>{f.label}</span>}{f.value && <b>{f.value}</b>}</li>
        ))}
      </ul>
    )}

    {hasFacts && variant === 'panel' && (
      <dl class="ctabox-readout">
        {shownFacts.map((f) => (
          <div><dt>{f.label}</dt><dd>{f.value}</dd></div>
        ))}
      </dl>
    )}
  </div>
</section>
