---
import Cover from '../src/Cover.astro';

// Image gallery — heading + intro + a responsive grid of images with optional
// captions. Falls back to a neutral placeholder when an image is missing, so the
// block is safe to add before real photos exist.
interface GalleryImage { image?: string; alt?: string; caption?: string }
interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  images?: GalleryImage[];
  columns?: number;
}
const { eyebrow, heading, intro, images = [], columns = 3 } = Astro.props;
const cols = columns === 2 ? 2 : 3;
---

{(heading || images.length > 0) && (
  <section class="section">
    {(eyebrow || heading || intro) && (
      <div class="section-head">
        {eyebrow && <span class="mono eyebrow">{eyebrow}</span>}
        {heading && <h2 class="display" style="margin-top:0.75rem">{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}
    <div class="gallery-grid" data-cols={cols}>
      {images.map((img) => (
        <figure class="gallery-item">
          <Cover src={img.image} alt={img.alt ?? ''} placeholder="/images/placeholder.svg" width={800} height={600} class="gallery-img" />
          {img.caption && <figcaption class="gallery-cap">{img.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </section>
)}
