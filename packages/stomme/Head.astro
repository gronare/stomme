---
// Engine-owned <head> meta: title, description, Open Graph, Twitter card, favicon +
// apple-touch-icon links (and, when a site emits them, a web manifest + theme-color).
// Encapsulated here so the social/SEO head is the stomme DEFAULT — engine-owned, so it
// can't be silently dropped when a site customizes its Base (a real past failure
// mode), and so head improvements ship fleet-wide via promote. Renders the SAME markup
// a site Base previously inlined; migrate a Base by replacing that block with
//   <StommeHead title={title} description={description} image={image} />
//
// og:image resolution: image ?? settings.ogImage, made absolute via Astro.site (social
// scrapers need absolute URLs). Unset ⇒ no og:image and twitter:card=summary (no broken
// image). manifest/themeColor are optional and render only when passed — the template
// omits both (identical output); a PWA/branded site supplies them.
import { getEntry } from 'astro:content';
// The integration-wired alias to the site's src/site.config.ts. Every stomme site runs
// the integration, so this resolves in any real build; it's only needed to scope the
// generated-OG-card lookup below.
// @ts-expect-error — virtual alias, no static types.
import { site, features, listings } from '@stomme/config';
import { resolveShareImage } from './src/og-pages.ts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  manifest?: string;
  themeColor?: string;
}
const { title, description, image, manifest, themeColor } = Astro.props;

const settings = (await getEntry('settings', 'site'))!.data;

// Favicon: site-set (settings.favicon) or the shipped default; an SVG scales to
// any tab size. settings.appleIcon is the optional iOS home-screen PNG.
const favicon = settings.favicon || '/favicon.svg';
const faviconType = favicon.endsWith('.svg') ? 'image/svg+xml'
  : favicon.endsWith('.png') ? 'image/png'
  : favicon.endsWith('.ico') ? 'image/x-icon' : undefined;

// Social-share card (og:image / Twitter). Absolute URL when the site URL is configured —
// social scrapers need absolute. Falls back to the raw value otherwise.
//
// resolveShareImage owns the whole layered model (src/og-pages.ts), using the SAME
// enumeration as the endpoint's getStaticPaths so a card URL is only produced when that
// card is emitted. Master off → Phase-1 (this page's override ?? settings.ogImage); on →
// per-page override → per-type generated card → site default (ogImage → home hero →
// brand card). `image` is the page's own override (seo.image) passed by its route.
const ogTitle = title ?? settings.name;
const shareImage = await resolveShareImage(Astro.url.pathname, image, { features, routes: site.routes, listings });
// Resolve an uploaded /media/… share image to its built URL (scrapers need a served URL); other paths pass through.
const uploadedAssetUrls = import.meta.glob('/src/assets/media/**/*', { query: '?url', import: 'default', eager: true }) as Record<string, string>;
const shareKey = shareImage && shareImage.startsWith('/media/') ? `/src/assets/media/${shareImage.slice('/media/'.length)}` : null;
const servedShareImage = shareKey ? (uploadedAssetUrls[shareKey] ?? shareImage) : shareImage;
const ogImage = servedShareImage
  ? (Astro.site ? new URL(servedShareImage, Astro.site).href : servedShareImage)
  : undefined;
const ogUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;

// Indexing + canonical. A site still on its *.pages.dev host is a pre-launch demo →
// noindex so search engines never index it. Once live (Astro.site = the real domain)
// it's indexable, and the canonical points at the real domain even when the same build
// is served via the *.pages.dev shadow — so the pages.dev copy defers, not competes.
const noindex = Astro.site ? new URL(Astro.site).hostname.endsWith('.pages.dev') : false;
---
<title>{title ?? settings.name}</title>
{description && <meta name="description" content={description} />}
{noindex && <meta name="robots" content="noindex, nofollow" />}
{ogUrl && <link rel="canonical" href={ogUrl} />}
<meta property="og:title" content={ogTitle} />
{description && <meta property="og:description" content={description} />}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={settings.name} />
{ogUrl && <meta property="og:url" content={ogUrl} />}
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
<link rel="icon" href={favicon} type={faviconType} />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
{settings.appleIcon && <link rel="apple-touch-icon" href={settings.appleIcon} />}
{manifest && <link rel="manifest" href={manifest} />}
{themeColor && <meta name="theme-color" content={themeColor} />}
