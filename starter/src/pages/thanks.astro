---
// Contact-form success page (no-JS fallback for /thanks). Renders the shared Thanks component
// from the "Thank-you" settings. Editable copy (heading/message/buttons) comes from the entry
// (pre-seeded in the starter, removable in the CMS — blank renders nothing); UI chrome (eyebrow,
// the recap/direct labels) stays localized. A direct page visit has no submitted data, so
// there's no "what you sent" recap here (the inline confirmation shows it); the preview mocks it.
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';
import { resolveSite } from '@gronare/stomme/config';
import { resolveLink } from '@gronare/stomme/href';
import Thanks from '@gronare/stomme/Thanks.astro';
import { site as siteConfig } from '../site.config';

const site = resolveSite(siteConfig);
const t = site.strings.thanks;
const settings = (await getEntry('settings', 'site'))!.data;
const contact: any = (await getEntry('contact', 'contact')?.catch(() => null))?.data ?? {};
const ts: any = (await getEntry('thanks', 'thanks')?.catch(() => null))?.data ?? {};
---
<Base title="Thank you" description={ts.message || t.lead}>
  <Thanks
    variant={ts.variant}
    town={contact.address?.city}
    toLabel={t.to}
    fromLabel={t.from}
    eyebrow={t.eyebrow}
    heading={(ts.heading ?? '').replace('{name}', '')}
    message={ts.message ?? ''}
    primaryLabel={ts.button?.label ?? ''}
    primaryHref={resolveLink(ts.button?.link, '/')}
    secondaryLabel={ts.button2?.label ?? ''}
    secondaryHref={resolveLink(ts.button2?.link, '/')}
    showContact={ts.showContact === true && !!(contact.phone || contact.email)}
    talkLabel={t.talkLabel}
    who={settings.name}
  />
</Base>
