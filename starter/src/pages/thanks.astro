---
// Contact-form success page (no-JS fallback for /thanks). Engine-rendered in the refreshed
// confirmation style from the "Thank-you" settings (localized fallback) — NOT a CMS Page.
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';
import { resolveSite } from '@gronare/stomme/config';
import { site as siteConfig } from '../site.config';

const site = resolveSite(siteConfig);
const t = site.strings.thanks;
const settings = (await getEntry('settings', 'site'))!.data;
const ts: any = (await getEntry('thanks', 'thanks').catch(() => null))?.data ?? {};
const heading = ts.heading || t.heading.replace('{name}', '');
const message = ts.message || t.lead;
const button = ts.buttonLabel || t.home;
const showContact = ts.showContact !== false;
---
<Base title="Thank you" description={message}>
  <section class="section">
    <div class="contact-sent">
      <div class="cs-badge"><svg viewBox="0 0 56 56" aria-hidden="true"><circle cx="28" cy="28" r="26"></circle><path d="M17 29.5 L24.5 37 L40 20"></path></svg></div>
      <p class="cs-eyebrow">{t.eyebrow}</p>
      <h1 class="cs-head">{heading}</h1>
      <p class="cs-lead">{message}</p>
      <div class="cs-actions"><a class="btn" href="/">{button}</a></div>
      {showContact && settings.phone && (
        <p class="cs-lead">{site.strings.contact.direct}: <a href={`tel:${settings.phoneE164}`}>{settings.phone}</a></p>
      )}
    </div>
  </section>
</Base>
