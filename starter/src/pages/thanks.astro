---
// Contact-form success page (no-JS fallback for /thanks). Renders the shared Thanks component
// from the "Thank-you" settings (localized fallback) — the same component the CMS preview shows.
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';
import { resolveSite } from '@gronare/stomme/config';
import Thanks from '@gronare/stomme/Thanks.astro';
import { site as siteConfig } from '../site.config';

const site = resolveSite(siteConfig);
const t = site.strings.thanks;
const settings = (await getEntry('settings', 'site'))!.data;
const ts: any = (await getEntry('thanks', 'thanks').catch(() => null))?.data ?? {};
const heading = ts.heading || t.heading.replace('{name}', '');
const message = ts.message || t.lead;
const button = ts.buttonLabel || t.home;
const showContact = ts.showContact !== false;
---
<Base title="Thank you" description={message}>
  <Thanks
    eyebrow={t.eyebrow}
    heading={heading}
    message={message}
    button={button}
    showContact={showContact}
    directLabel={site.strings.contact.direct}
    phone={settings.phone}
    phoneE164={settings.phoneE164}
    email={settings.email}
    hours={settings.openingHours}
  />
</Base>
