---
// CMS live-preview target — the only on-demand (SSR) route. The admin serialises
// the unsaved draft to base64 and points an iframe here, so the preview renders
// the REAL components and never drifts from production.
//
// Default (no `kind`): renders the page `blocks` array via BlockRenderer.
// `?kind=header` / `?kind=footer`: renders the real chrome with the draft nav/footer
// object injected (the draft is merged over the live collections so partial drafts
// still render).
export const prerender = __STOMME_STATIC__;
import Base from '../layouts/Base.astro';
import BlockRenderer from '@gronare/stomme/BlockRenderer.astro';
import Header from '@gronare/stomme/Header.astro';
import Footer from '@gronare/stomme/Footer.astro';

const kind = Astro.url.searchParams.get('kind');
const raw = Astro.url.searchParams.get('data');

function decode(): any {
  if (!raw) return null;
  try {
    return JSON.parse(Buffer.from(raw, 'base64').toString('utf8'));
  } catch {
    return null; // ignore malformed drafts
  }
}
const draft = decode();

let blocks: { type: string }[] = [];
if (!kind && Array.isArray(draft)) blocks = draft;

// For chrome previews the draft is the nav/footer entry object. Header reads `nav`;
// Footer reads `footer` + still pulls nav.logo + settings from the live collections.
const navDraft = kind === 'header' && draft && typeof draft === 'object' ? draft : undefined;
const footerDraft = kind === 'footer' && draft && typeof draft === 'object' ? draft : undefined;
---
{kind === 'header' ? (
  <Base title="Preview" chrome={false}>
    <Header nav={navDraft} />
  </Base>
) : kind === 'footer' ? (
  <Base title="Preview" chrome={false}>
    <Footer footer={footerDraft} />
  </Base>
) : (
  <Base title="Preview">
    <div id="preview-root"><BlockRenderer blocks={blocks} /></div>
  </Base>
)}
<script is:inline>
  // Re-render on a new draft from the CMS (full reload keeps it simple + correct).
  window.addEventListener('message', (e) => {
    if (e.data && e.data.type === 'stomme:preview' && typeof e.data.data === 'string') {
      const u = new URL(location.href);
      u.searchParams.set('data', e.data.data);
      location.replace(u.toString());
    }
  });
</script>
