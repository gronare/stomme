---
import Base from '../layouts/Base.astro';
import BlockRenderer from '@gronare/stomme/BlockRenderer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // Unpublished pages (published: false) aren't built — the owner can hide a page (e.g.
  // the contact form) from the CMS without deleting it. It 404s until re-published.
  const pages = (await getCollection('pages')).filter((p) => p.data.published !== false);
  return pages.map((p) => ({ params: { slug: p.id }, props: { page: p } }));
}
const { page } = Astro.props;
---
<Base title={page.data.seo.title} description={page.data.seo.description}>
  <BlockRenderer blocks={page.data.blocks} />
</Base>
